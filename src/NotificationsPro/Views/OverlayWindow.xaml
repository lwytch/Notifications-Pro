<Window x:Class="NotificationsPro.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:NotificationsPro.Converters"
        Title="Notifications Pro Overlay"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Height"
        Topmost="{Binding AlwaysOnTop}"
        Width="{Binding OverlayWidth, Mode=TwoWay}"
        MaxHeight="{Binding OverlayMaxHeight}"
        MinHeight="1" MinWidth="200"
        AutomationProperties.Name="Notifications Pro Overlay"
        AutomationProperties.LiveSetting="Assertive">

    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <converters:ColorToOpacityBrushConverter x:Key="ColorToOpacityBrush"/>
        <converters:AppTintBrushConverter x:Key="AppTintBrush"/>
        <converters:NotificationTextVisibilityConverter x:Key="NotificationTextVisibility"/>
        <converters:NotificationOneLineContentConverter x:Key="NotificationOneLineContent"/>
        <converters:AppIconConverter x:Key="AppIconConverter"/>
        <converters:TimestampTextConverter x:Key="TimestampText"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Notification card template -->
        <DataTemplate x:Key="NotificationCardTemplate">
            <Border x:Name="Card"
                    Margin="{Binding DataContext.CardMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                    CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                    BorderBrush="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                    BorderThickness="{Binding DataContext.CardBorderThickness, RelativeSource={RelativeSource AncestorType=Window}}"
                    Opacity="1"
                    Loaded="OnCardLoaded">
                <Border.RenderTransform>
                    <TranslateTransform X="0"/>
                </Border.RenderTransform>

                <Grid>
                    <!-- Highlight tint overlay — sits outside AccentBorder so it covers the full card (no padding offset).
                         Background binds to the per-notification HighlightColor so each keyword can have a unique shade. -->
                    <Border x:Name="HighlightOverlay"
                            CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                            Opacity="0"
                            IsHitTestVisible="False"
                            Background="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"
                            Panel.ZIndex="1"/>

                <Border x:Name="AccentBorder"
                        CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                        Padding="{Binding DataContext.Padding, RelativeSource={RelativeSource AncestorType=Window}}"
                        BorderBrush="{Binding DataContext.AccentColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                        BorderThickness="{Binding DataContext.AccentBorderThickness, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource AppTintBrush}">
                            <Binding Path="AppName"/>
                            <Binding Path="DataContext.PerAppTintEnabled" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.PerAppTintOpacity" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.BackgroundColor" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.BackgroundOpacity" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon column -->
                    <Image Grid.Column="0" VerticalAlignment="Top"
                           Width="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                           Height="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                           Margin="0,0,8,0"
                           Stretch="Uniform"
                           Visibility="{Binding DataContext.ShowNotificationIcons, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource AppIconConverter}">
                                <Binding Path="AppName"/>
                                <Binding Path="DataContext.IconService" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                <Binding Path="DataContext.CurrentSettings" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            </MultiBinding>
                        </Image.Source>
                    </Image>

                    <!-- Content column -->
                    <Grid Grid.Column="1">
                    <StackPanel x:Name="StackedContent"
                                Visibility="{Binding DataContext.StackedContentVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                        <!-- App name -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.AppNameFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.AppNameFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   MaxHeight="{Binding DataContext.AppNameEffectiveMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   Margin="0,0,0,4"
                                   LineHeight="{Binding DataContext.AppNameLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="None"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.LimitTextLines, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="AppName"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="AppName"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Title -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.TitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.TitleFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   MaxHeight="{Binding DataContext.TitleEffectiveMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   Margin="0,0,0,4"
                                   LineHeight="{Binding DataContext.TitleLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="None"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.LimitTextLines, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="Title"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Title"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Body -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   MaxHeight="{Binding DataContext.BodyEffectiveMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   LineHeight="{Binding DataContext.BodyLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="None"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.LimitTextLines, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="Body"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Body"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Timestamp -->
                        <TextBlock Visibility="{Binding DataContext.TimestampVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.TimestampFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.TimestampFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TimestampColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   Opacity="0.7"
                                   Margin="0,4,0,0">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource TimestampText}">
                                    <Binding Path="RelativeTimeText"/>
                                    <Binding Path="ReceivedAt"/>
                                    <Binding Path="DataContext.TimestampDisplayMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- One-line banner mode -->
                    <Grid x:Name="SingleLineContent"
                          Visibility="{Binding DataContext.SingleLineContentVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Grid x:Name="SingleLineCompactBlock"
                              Visibility="{Binding DataContext.SingleLineCompactVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SingleLineApp"
                                       Grid.Column="0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="None"
                                       FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="{Binding DataContext.AppNameFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontWeight="{Binding DataContext.AppNameFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="AppName"/>
                                </TextBlock.Text>
                                <TextBlock.Visibility>
                                    <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                    </MultiBinding>
                                </TextBlock.Visibility>
                            </TextBlock>

                            <TextBlock x:Name="SingleLineBody"
                                       Grid.Column="1"
                                       Margin="8,0,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                       VerticalAlignment="Center">
                                <Run Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                    <Run.Text>
                                        <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:title" Mode="OneWay">
                                            <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="Title"/>
                                            <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="Body"/>
                                        </MultiBinding>
                                    </Run.Text>
                                </Run>
                                <Run Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                    <Run.Text>
                                        <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:body" Mode="OneWay">
                                            <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="Title"/>
                                            <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="Body"/>
                                        </MultiBinding>
                                    </Run.Text>
                                </Run>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ShowAppName, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AppName}" Value="">
                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <TextBlock x:Name="SingleLineWrappedText"
                                   Visibility="{Binding DataContext.SingleLineWrappedVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   LineHeight="{Binding DataContext.BodyLineHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   MaxHeight="{Binding DataContext.SingleLineWrappedMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True">
                            <Run Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:app;full" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:title;full" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:body;full" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                        </TextBlock>
                    </Grid>
                    </Grid>
                </Grid>
                </Border>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <!-- Highlight accent override for keyword-matched notifications -->
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <!-- Recolour the accent stripe using the per-notification HighlightColor -->
                    <Setter TargetName="AccentBorder" Property="BorderBrush"
                            Value="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"/>
                    <!-- Show the background tint overlay -->
                    <Setter TargetName="HighlightOverlay" Property="Opacity" Value="0.18"/>
                    <!-- Also frame the outer card with the highlight colour -->
                    <Setter TargetName="Card" Property="BorderBrush"
                            Value="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"/>
                    <Setter TargetName="Card" Property="BorderThickness" Value="0,1,1,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExpiring}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="50" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- Main content: tiny alpha preserves drag hit-testing without a visible panel -->
    <Grid Margin="{Binding OuterContentMargin}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="#01000000"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ChromaKeyEnabled}" Value="True">
                        <Setter Property="Background" Value="{Binding ChromaKeyColor, Converter={StaticResource ColorToBrush}}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <ScrollViewer x:Name="NotificationScrollViewer"
                      VerticalScrollBarVisibility="{Binding ScrollbarVisibility}"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="None"
                      MaxHeight="{Binding OverlayMaxHeight}">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="{Binding DataContext.OverlayScrollbarWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                    <Setter Property="Opacity" Value="{Binding DataContext.OverlayScrollbarOpacity, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                </Style>
            </ScrollViewer.Resources>
            <StackPanel>
                <!-- Empty state ghost card -->
                <Border Visibility="{Binding EmptyStateVisibility}"
                        Margin="{Binding CardMargin}"
                        CornerRadius="{Binding CornerRadius}"
                        Opacity="0.35" Padding="{Binding Padding}">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                            <Binding Path="BackgroundColor"/>
                            <Binding Path="BackgroundOpacity"/>
                        </MultiBinding>
                    </Border.Background>
                    <TextBlock Text="Waiting for notifications..."
                               FontFamily="{Binding FontFamily}"
                               FontSize="{Binding FontSize}"
                               Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                               Opacity="0.6"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Notification items -->
                <ItemsControl ItemsSource="{Binding Notifications}"
                              ItemTemplate="{StaticResource NotificationCardTemplate}"/>

                <!-- Overflow indicator -->
                <Border x:Name="OverflowBadge"
                        Visibility="{Binding Queue.HasOverflow, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,4" Padding="12,8"
                        CornerRadius="{Binding CornerRadius}"
                        HorizontalAlignment="Left">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                            <Binding Path="BackgroundColor"/>
                            <Binding Path="BackgroundOpacity"/>
                        </MultiBinding>
                    </Border.Background>
                    <TextBlock Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                               FontSize="{Binding FontSize}"
                               FontFamily="{Binding FontFamily}">
                        <Run Text="+"/><Run Text="{Binding Queue.OverflowCount, Mode=OneWay}"/>
                        <Run Text="more"/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
