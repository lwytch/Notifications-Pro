<Window x:Class="NotificationsPro.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:NotificationsPro.Converters"
        Title="Notifications Pro Overlay"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Height"
        Topmost="{Binding AlwaysOnTop}"
        Width="{Binding OverlayWidth, Mode=TwoWay}"
        MaxHeight="{Binding OverlayMaxHeight}"
        MinHeight="1" MinWidth="200"
        AutomationProperties.Name="Notifications Pro Overlay"
        AutomationProperties.LiveSetting="Assertive">

    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <converters:ColorToOpacityBrushConverter x:Key="ColorToOpacityBrush"/>
        <converters:AppTintBrushConverter x:Key="AppTintBrush"/>
        <converters:NotificationBackgroundImageSourceConverter x:Key="NotificationBackgroundImageSource"/>
        <converters:NotificationTextVisibilityConverter x:Key="NotificationTextVisibility"/>
        <converters:NotificationOneLineContentConverter x:Key="NotificationOneLineContent"/>
        <converters:AppIconConverter x:Key="AppIconConverter"/>
        <converters:TimestampTextConverter x:Key="TimestampText"/>
        <converters:VoiceAccessAutomationNameConverter x:Key="VoiceAccessAutomationName"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Notification card template -->
        <DataTemplate x:Key="NotificationCardTemplate">
            <Border x:Name="Card"
                    Margin="{Binding DataContext.CardMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                    CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                    BorderBrush="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                    BorderThickness="{Binding DataContext.CardBorderThickness, RelativeSource={RelativeSource AncestorType=Window}}"
                    Opacity="1"
                    RenderTransformOrigin="0.5,0.5"
                    Loaded="OnCardLoaded">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>

                <Grid>
                <Border x:Name="AccentBorder"
                        CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                        ClipToBounds="True"
                        BorderBrush="{Binding DataContext.AccentColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                        BorderThickness="{Binding DataContext.AccentBorderThickness, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource AppTintBrush}">
                            <Binding Path="AppName"/>
                            <Binding Path="DataContext.PerAppTintEnabled" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.PerAppTintOpacity" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.BackgroundColor" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="DataContext.BackgroundOpacity" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </Border.Background>

                <Grid>
                    <Image Opacity="{Binding BackgroundImageOpacity}"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Stretch" Value="UniformToFill"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding BackgroundImageMode}" Value="Image"/>
                                            <Condition Binding="{Binding BackgroundImagePlacement}" Value="Full Card"/>
                                            <Condition Binding="{Binding DataContext.SingleLineMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageFitMode}" Value="Fit Inside Card">
                                        <Setter Property="Stretch" Value="Uniform"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageFitMode}" Value="Original Size">
                                        <Setter Property="Stretch" Value="None"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageVerticalFocus}" Value="Top">
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageVerticalFocus}" Value="Bottom">
                                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource NotificationBackgroundImageSource}">
                                <Binding Path="BackgroundImagePath"/>
                                <Binding Path="BackgroundImageHueDegrees"/>
                                <Binding Path="BackgroundImageBrightness"/>
                                <Binding Path="BackgroundImageSaturation"/>
                                <Binding Path="BackgroundImageContrast"/>
                                <Binding Path="BackgroundImageBlackAndWhite"/>
                            </MultiBinding>
                        </Image.Source>
                    </Image>

                    <Image Opacity="{Binding BackgroundImageOpacity}"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="{Binding DataContext.Padding, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Stretch" Value="UniformToFill"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding BackgroundImageMode}" Value="Image"/>
                                            <Condition Binding="{Binding BackgroundImagePlacement}" Value="Inside Padding"/>
                                            <Condition Binding="{Binding DataContext.SingleLineMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageFitMode}" Value="Fit Inside Card">
                                        <Setter Property="Stretch" Value="Uniform"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageFitMode}" Value="Original Size">
                                        <Setter Property="Stretch" Value="None"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageVerticalFocus}" Value="Top">
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageVerticalFocus}" Value="Bottom">
                                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource NotificationBackgroundImageSource}">
                                <Binding Path="BackgroundImagePath"/>
                                <Binding Path="BackgroundImageHueDegrees"/>
                                <Binding Path="BackgroundImageBrightness"/>
                                <Binding Path="BackgroundImageSaturation"/>
                                <Binding Path="BackgroundImageContrast"/>
                                <Binding Path="BackgroundImageBlackAndWhite"/>
                            </MultiBinding>
                        </Image.Source>
                    </Image>

                    <!-- Highlight tint sits between background treatments and the content layer so text stays readable. -->
                    <Border x:Name="HighlightOverlay"
                            CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                            Opacity="0"
                            IsHitTestVisible="False"
                            Background="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"/>

                    <Grid Margin="{Binding DataContext.Padding, RelativeSource={RelativeSource AncestorType=Window}}"
                          ClipToBounds="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon column -->
                        <Image Grid.Column="0" VerticalAlignment="Top"
                               Width="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                               Height="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="0,0,8,0"
                               Stretch="Uniform"
                               Visibility="{Binding DataContext.ShowNotificationIcons, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource AppIconConverter}">
                                    <Binding Path="AppName"/>
                                    <Binding Path="DataContext.IconService" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="DataContext.CurrentSettings" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>

                        <!-- Content column -->
                        <Grid Grid.Column="1">
                    <StackPanel x:Name="StackedContent"
                                Visibility="{Binding DataContext.StackedContentVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                        <!-- App name -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.AppNameFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.AppNameFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="{Binding DataContext.TextAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                   MaxHeight="{Binding DataContext.AppNameEffectiveMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   Margin="0,0,0,4"
                                   LineHeight="{Binding DataContext.AppNameLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="None"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.LimitTextLines, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="AppName"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="AppName"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Title -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.TitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.TitleFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="{Binding DataContext.TextAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                   MaxHeight="{Binding DataContext.TitleEffectiveMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   Margin="0,0,0,4"
                                   LineHeight="{Binding DataContext.TitleLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="None"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.LimitTextLines, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="Title"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Title"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Body -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="{Binding DataContext.TextAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                   MaxHeight="{Binding DataContext.BodyEffectiveMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   LineHeight="{Binding DataContext.BodyLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="None"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.LimitTextLines, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <Binding Path="Body"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Body"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Timestamp -->
                        <TextBlock Visibility="{Binding DataContext.TimestampVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.TimestampFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.TimestampFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TimestampColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   Opacity="0.7"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="{Binding DataContext.TextAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,4,0,0">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource TimestampText}">
                                    <Binding Path="RelativeTimeText"/>
                                    <Binding Path="ReceivedAt"/>
                                    <Binding Path="DataContext.TimestampDisplayMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- One-line banner mode -->
                    <Grid x:Name="SingleLineContent"
                          Visibility="{Binding DataContext.SingleLineContentVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                        <TextBlock x:Name="SingleLineCompactBlock"
                                   Visibility="{Binding DataContext.SingleLineCompactVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="{Binding DataContext.TextAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   VerticalAlignment="Center">
                            <Run Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:app" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:title" Mode="OneWay">
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:body" Mode="OneWay">
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Text=" " />
                            <InlineUIContainer BaselineAlignment="Center">
                                <TextBlock Visibility="{Binding DataContext.TimestampVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="{Binding DataContext.TimestampFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontWeight="{Binding DataContext.TimestampFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Foreground="{Binding DataContext.TimestampColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                           Opacity="0.7">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource TimestampText}">
                                            <Binding Path="RelativeTimeText"/>
                                            <Binding Path="ReceivedAt"/>
                                            <Binding Path="DataContext.TimestampDisplayMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </InlineUIContainer>
                        </TextBlock>

                        <TextBlock x:Name="SingleLineWrappedText"
                                   Visibility="{Binding DataContext.SingleLineWrappedVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="{Binding DataContext.TextAlignment, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   LineHeight="{Binding DataContext.BodyLineHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   MaxHeight="{Binding DataContext.SingleLineWrappedMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True">
                            <Run Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:app;full" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:title;full" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <Run Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}">
                                <Run.Text>
                                    <MultiBinding Converter="{StaticResource NotificationOneLineContent}" ConverterParameter="segment:body;full" Mode="OneWay">
                                        <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="AppName"/>
                                        <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Title"/>
                                        <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Body"/>
                                    </MultiBinding>
                                </Run.Text>
                            </Run>
                            <!-- Inline Timestamp -->
                            <Run Text=" " />
                            <InlineUIContainer BaselineAlignment="Center">
                                <TextBlock Visibility="{Binding DataContext.TimestampVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="{Binding DataContext.TimestampFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontWeight="{Binding DataContext.TimestampFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Foreground="{Binding DataContext.TimestampColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                           Opacity="0.7">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource TimestampText}">
                                            <Binding Path="RelativeTimeText"/>
                                            <Binding Path="ReceivedAt"/>
                                            <Binding Path="DataContext.TimestampDisplayMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </InlineUIContainer>
                        </TextBlock>
                    </Grid>
                    </Grid>
                    </Grid>
                </Grid>
                </Border>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <!-- Highlight accent override for keyword-matched notifications -->
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <!-- Recolour the accent stripe using the per-notification HighlightColor -->
                    <Setter TargetName="AccentBorder" Property="BorderBrush"
                            Value="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"/>
                    <!-- Show the background tint overlay -->
                    <Setter TargetName="HighlightOverlay" Property="Opacity"
                            Value="{Binding HighlightOverlayOpacity}"/>
                    <!-- Also frame the outer card with the highlight colour -->
                    <Setter TargetName="Card" Property="BorderBrush"
                            Value="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"/>
                    <Setter TargetName="Card" Property="BorderThickness"
                            Value="{Binding HighlightCardBorderThickness}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExpiring}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="50" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- Main content: tiny alpha preserves drag hit-testing without a visible panel -->
    <Grid Margin="{Binding OuterContentMargin}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="#01000000"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ChromaKeyEnabled}" Value="True">
                        <Setter Property="Background" Value="{Binding ChromaKeyColor, Converter={StaticResource ColorToBrush}}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <ScrollViewer x:Name="NotificationScrollViewer"
                      VerticalScrollBarVisibility="{Binding ScrollbarVisibility}"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="None"
                      ScrollChanged="OnNotificationScrollChanged"
                      MaxHeight="{Binding OverlayMaxHeight}">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="{Binding DataContext.OverlayScrollbarWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                    <Setter Property="Opacity" Value="{Binding DataContext.OverlayScrollbarOpacity, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Border Background="{Binding DataContext.OverlayScrollbarTrackColor, RelativeSource={RelativeSource AncestorType=ScrollBar}, Converter={StaticResource ColorToBrush}}"
                                            CornerRadius="{Binding DataContext.OverlayScrollbarCornerRadiusValue, RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                            Margin="{Binding DataContext.OverlayScrollbarPaddingThickness, RelativeSource={RelativeSource AncestorType=ScrollBar}}"/>
                                    <Track x:Name="PART_Track"
                                           Margin="{Binding DataContext.OverlayScrollbarPaddingThickness, RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                           IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb Background="Transparent">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="{Binding DataContext.OverlayScrollbarThumbColor, RelativeSource={RelativeSource AncestorType=ScrollBar}, Converter={StaticResource ColorToBrush}}"
                                                                CornerRadius="{Binding DataContext.OverlayScrollbarCornerRadiusValue, RelativeSource={RelativeSource AncestorType=ScrollBar}}"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background"
                                                                        Value="{Binding DataContext.OverlayScrollbarThumbHoverColor, RelativeSource={RelativeSource AncestorType=ScrollBar}, Converter={StaticResource ColorToBrush}}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background"
                                                                        Value="{Binding DataContext.OverlayScrollbarThumbHoverColor, RelativeSource={RelativeSource AncestorType=ScrollBar}, Converter={StaticResource ColorToBrush}}"/>
                                                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.92"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Resources>
            <StackPanel Margin="{Binding OverlayContentMargin}">
                <!-- Search bar (toggled via right-click context menu) -->
                <Border Visibility="{Binding SearchBarVisibility}"
                        Margin="0,0,0,4"
                        CornerRadius="{Binding CornerRadius}"
                        Padding="8,6">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                            <Binding Path="BackgroundColor"/>
                            <Binding Path="BackgroundOpacity"/>
                        </MultiBinding>
                    </Border.Background>
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{Binding FontFamily}"
                             FontSize="{Binding FontSize}"
                             Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                             VerticalContentAlignment="Center"/>
                </Border>

                <!-- Empty state ghost card -->
                <Border Visibility="{Binding EmptyStateVisibility}"
                        Margin="{Binding CardMargin}"
                        CornerRadius="{Binding CornerRadius}"
                        Opacity="0.35" Padding="{Binding Padding}">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                            <Binding Path="BackgroundColor"/>
                            <Binding Path="BackgroundOpacity"/>
                        </MultiBinding>
                    </Border.Background>
                    <TextBlock Text="Waiting for notifications..."
                               FontFamily="{Binding FontFamily}"
                               FontSize="{Binding FontSize}"
                               Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                               Opacity="0.6"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Notification items -->
                <ItemsControl x:Name="NotificationItemsControl"
                              ItemsSource="{Binding NotificationsView}"
                              AutomationProperties.Name="Visible notifications"
                              ItemTemplate="{StaticResource NotificationCardTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Focusable" Value="True"/>
                            <Setter Property="AutomationProperties.Name">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource VoiceAccessAutomationName}">
                                        <Binding Path="Title"/>
                                        <Binding Path="Body"/>
                                        <Binding Path="RelativeTimeText"/>
                                        <Binding Path="ReceivedAt"/>
                                        <Binding Path="DataContext.VoiceAccessReadMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.TimestampDisplayMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="AutomationProperties.HelpText" Value="Notification overlay item"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <Border x:Name="GroupContainer"
                                                        Margin="0"
                                                        Padding="10,10,10,2"
                                                        CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        BorderBrush="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                                        BorderThickness="1"
                                                        Background="Transparent">
                                                    <StackPanel>
                                                        <StackPanel Margin="0,0,0,8">
                                                            <Grid HorizontalAlignment="Left">
                                                                <Border x:Name="NeutralHeaderSurface"
                                                                        CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        BorderBrush="{Binding DataContext.AccentColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                                                        BorderThickness="1">
                                                                    <Border.Background>
                                                                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                                                                            <Binding Path="DataContext.BackgroundColor" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                            <Binding Path="DataContext.BackgroundOpacity" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </Border.Background>
                                                                </Border>

                                                                <Border x:Name="AccentHeaderSurface"
                                                                        Visibility="Collapsed"
                                                                        CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Background="{Binding DataContext.AccentColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                                                        BorderBrush="{Binding DataContext.AccentColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                                                        BorderThickness="1"/>

                                                                <StackPanel Orientation="Horizontal" Margin="10,6">
                                                                    <TextBlock x:Name="GroupHeaderText"
                                                                               Text="{Binding Name}"
                                                                               FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               FontSize="{Binding DataContext.AppNameFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"/>
                                                                    <TextBlock x:Name="GroupHeaderCount"
                                                                               Text="{Binding ItemCount, StringFormat='{} ({0})'}"
                                                                               Margin="6,0,0,0"
                                                                               FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                                                               Visibility="{Binding DataContext.ShowAppGroupCounts, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <Border x:Name="GroupHeaderDivider"
                                                                    Height="1"
                                                                    Margin="0,6,0,0"
                                                                    Visibility="Collapsed"
                                                                    Background="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"/>
                                                        </StackPanel>

                                                        <ItemsPresenter/>
                                                    </StackPanel>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.AppGroupingStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Header Chip">
                                                        <Setter TargetName="GroupContainer" Property="BorderThickness" Value="0"/>
                                                        <Setter TargetName="GroupContainer" Property="Padding" Value="0"/>
                                                        <Setter TargetName="NeutralHeaderSurface" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="AccentHeaderSurface" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="GroupHeaderText" Property="Foreground" Value="White"/>
                                                        <Setter TargetName="GroupHeaderCount" Property="Foreground" Value="White"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding DataContext.AppGroupingStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="Minimal Label">
                                                        <Setter TargetName="GroupContainer" Property="BorderThickness" Value="0"/>
                                                        <Setter TargetName="GroupContainer" Property="Padding" Value="0"/>
                                                        <Setter TargetName="NeutralHeaderSurface" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="AccentHeaderSurface" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="GroupHeaderDivider" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                </ItemsControl>

                <!-- Overflow indicator -->
                <Border x:Name="OverflowBadge"
                        Visibility="{Binding Queue.HasOverflow, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,4" Padding="12,8"
                        CornerRadius="{Binding CornerRadius}"
                        HorizontalAlignment="Left"
                        Cursor="Hand"
                        ToolTip="Scrollbars only help when the currently retained cards exceed the overlay height. Notifications beyond the retained limit are discarded immediately for privacy and only counted here.">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                            <Binding Path="BackgroundColor"/>
                            <Binding Path="BackgroundOpacity"/>
                        </MultiBinding>
                    </Border.Background>
                    <TextBlock Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                               FontSize="{Binding FontSize}"
                               FontFamily="{Binding FontFamily}">
                        <Run Text="+"/><Run Text="{Binding Queue.OverflowCount, Mode=OneWay}"/>
                        <Run Text=" not shown"/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
