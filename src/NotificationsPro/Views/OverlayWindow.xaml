<Window x:Class="NotificationsPro.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:NotificationsPro.Converters"
        Title="Notifications Pro Overlay"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Height"
        Topmost="{Binding AlwaysOnTop}"
        Width="{Binding OverlayWidth, Mode=TwoWay}"
        MaxHeight="{Binding OverlayMaxHeight}"
        MinHeight="1" MinWidth="200">

    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <converters:ColorToOpacityBrushConverter x:Key="ColorToOpacityBrush"/>
        <converters:NotificationTextVisibilityConverter x:Key="NotificationTextVisibility"/>
        <converters:NotificationOneLineContentConverter x:Key="NotificationOneLineContent"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Slide-in storyboard -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-420" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <!-- Notification card template -->
        <DataTemplate x:Key="NotificationCardTemplate">
            <Border x:Name="Card" Margin="0,0,0,8" CornerRadius="{Binding DataContext.CornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                    Padding="{Binding DataContext.Padding, RelativeSource={RelativeSource AncestorType=Window}}"
                    Opacity="1">
                <Border.Background>
                    <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                        <Binding Path="DataContext.BackgroundColor" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.BackgroundOpacity" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Border.Background>
                <Border.BorderBrush>
                    <Binding Path="DataContext.AccentColor"
                             RelativeSource="{RelativeSource AncestorType=Window}"
                             Converter="{StaticResource ColorToBrush}"/>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness Left="3" Top="0" Right="0" Bottom="0"/>
                </Border.BorderThickness>
                <Border.RenderTransform>
                    <TranslateTransform X="0"/>
                </Border.RenderTransform>

                <Grid>
                    <StackPanel x:Name="StackedContent">
                        <!-- App name -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="{Binding DataContext.AppNameMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   Margin="0,0,0,4"
                                   LineHeight="{Binding DataContext.BodyLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Text>
                                <Binding Path="AppName"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="AppName"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Title -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.TitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.TitleColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="{Binding DataContext.TitleMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   Margin="0,0,0,4"
                                   LineHeight="{Binding DataContext.TitleLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Text>
                                <Binding Path="Title"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Title"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Body -->
                        <TextBlock FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="{Binding DataContext.BodyMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   ClipToBounds="True"
                                   LineHeight="{Binding DataContext.BodyLineHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock.Text>
                                <Binding Path="Body"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Body"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </StackPanel>

                    <!-- One-line banner mode -->
                    <Grid x:Name="SingleLineContent" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="SingleLineApp"
                                   Grid.Column="0"
                                   MaxWidth="200"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.AppNameColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   VerticalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="AppName"/>
                            </TextBlock.Text>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource NotificationTextVisibility}">
                                    <Binding Path="DataContext.ShowAppName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="AppName"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <TextBlock x:Name="SingleLineBody"
                                   Grid.Column="1"
                                   Margin="8,0,0,0"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="{Binding DataContext.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="{Binding DataContext.FontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{Binding DataContext.TextColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorToBrush}}"
                                   VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource NotificationOneLineContent}">
                                    <Binding Path="DataContext.ShowNotificationTitle" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Title"/>
                                    <Binding Path="DataContext.ShowNotificationBody" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Body"/>
                                </MultiBinding>
                            </TextBlock.Text>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.ShowAppName, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppName}" Value="">
                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SlideIn}"/>
                </EventTrigger>
                <DataTrigger Binding="{Binding DataContext.SingleLineMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter TargetName="StackedContent" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SingleLineContent" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExpiring}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="50" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- Main content: tiny alpha preserves drag hit-testing without a visible panel -->
    <Grid Margin="4" Background="#01000000">
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                      PanningMode="None"
                      MaxHeight="{Binding OverlayMaxHeight}">
            <StackPanel>
                <!-- Notification items -->
                <ItemsControl ItemsSource="{Binding Notifications}"
                              ItemTemplate="{StaticResource NotificationCardTemplate}"/>

                <!-- Overflow indicator -->
                <Border x:Name="OverflowBadge"
                        Visibility="{Binding Queue.HasOverflow, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,4" Padding="12,8" CornerRadius="8"
                        HorizontalAlignment="Left">
                    <Border.Background>
                        <SolidColorBrush Color="#1E1E2E" Opacity="0.8"/>
                    </Border.Background>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                               FontFamily="Segoe UI">
                        <Run Text="+"/><Run Text="{Binding Queue.OverflowCount, Mode=OneWay}"/>
                        <Run Text="more"/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
