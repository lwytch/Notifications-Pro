<Window x:Class="NotificationsPro.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:NotificationsPro.Converters"
        Title="Notifications Pro — Settings"
        Icon="{Binding TrayIconImage}"
        Width="780" Height="560" MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        ResizeMode="CanResize"
        AutomationProperties.Name="Notifications Pro Settings">

    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <converters:ColorToOpacityBrushConverter x:Key="ColorToOpacityBrush"/>
        <converters:BoolToMuteLabelConverter x:Key="BoolToMuteLabel"/>
        <converters:ZeroToVisibleConverter x:Key="ZeroToVisible"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Section header panel — no border/padding, text stays perfectly aligned -->
        <Style x:Key="SectionHeaderPanel" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>

        <!-- Section header text — larger + accent color for clear distinction -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0"/>
            <!-- Tooltip set per-instance where needed -->
        </Style>

        <!-- Setting label -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <!-- Setting description -->
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,8"/>
        </Style>

        <!-- Value display next to slider -->
        <Style x:Key="SliderValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="ColorPickButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="{Binding SettingsWindowCornerRadius}"
            Background="{DynamicResource WindowBgBrush}"
            ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20">
            <DockPanel LastChildFill="True">
                <Image Source="{Binding TrayIconImage}" Width="28" Height="28"
                       Margin="0,0,12,0" VerticalAlignment="Top"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Content="&#xE10E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Style="{StaticResource SecondaryButton}" Padding="6,4" Margin="0,0,4,0"
                            Command="{Binding UndoCommand}"
                            IsEnabled="{Binding CanUndo}"
                            ToolTip="Undo last change (Ctrl+Z)"/>
                    <Button Content="&#xE10D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Style="{StaticResource SecondaryButton}" Padding="6,4" Margin="0,0,12,0"
                            Command="{Binding RedoCommand}"
                            IsEnabled="{Binding CanRedo}"
                            ToolTip="Redo last undone change (Ctrl+Y)"/>
                    <TextBlock Text="Preview" FontFamily="{StaticResource UIFont}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ShowPreviewCard}"
                                  ToolTip="Show or hide the live preview card" Margin="0,0,16,0"/>

                    <Border Width="1" Height="16" Background="{DynamicResource BorderBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>

                    <!-- Window Controls (needed when in Popup mode) -->
                    <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Style="{StaticResource SecondaryButton}" Padding="8,6" Margin="0,0,4,0"
                            Click="OnMinimizeClick" ToolTip="Minimize to tray"/>
                    <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Style="{StaticResource SecondaryButton}" Padding="8,6"
                            Click="OnCloseClick" ToolTip="Close"/>
                </StackPanel>
                <TextBlock Text="Notifications Pro" FontFamily="{StaticResource UIFont}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- First-run tip bar -->
        <Border Grid.Row="1" Padding="16,10" Background="{DynamicResource SurfaceLightBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Visibility="{Binding ShowFirstRunTip, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Got it" Margin="12,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissFirstRunTipCommand}"/>
                <TextBlock Text="Quick tips: Use the left sidebar to switch sections. Overlay themes are under Appearance. Settings-window theme lives in UI Styling. Use Ctrl+T for a test notification."
                           FontFamily="{StaticResource UIFont}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <!-- Live preview card -->
        <Border Grid.Row="2" Padding="24,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Visibility="{Binding ShowPreviewCard, Converter={StaticResource BoolToVis}}">
            <Border x:Name="PreviewCardOuter" CornerRadius="{Binding CornerRadius}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{Binding BorderColor, Converter={StaticResource ColorToBrush}}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowBorder}" Value="True">
                                <Setter Property="BorderThickness" Value="{Binding BorderThickness}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border x:Name="PreviewCardAccent" CornerRadius="{Binding CornerRadius}" Padding="{Binding Padding}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowAccent}" Value="True">
                                    <Setter Property="BorderThickness">
                                        <Setter.Value>
                                            <Thickness Left="3" Top="0" Right="0" Bottom="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ColorToOpacityBrush}">
                            <Binding Path="BackgroundColor"/>
                            <Binding Path="BackgroundOpacity"/>
                        </MultiBinding>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="Microsoft Teams"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="{Binding AppNameFontSize}"
                                   FontWeight="{Binding AppNameFontWeight}"
                                   Foreground="{Binding AppNameColor, Converter={StaticResource ColorToBrush}}"
                                   Visibility="{Binding ShowAppName, Converter={StaticResource BoolToVis}}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Sarah sent a message"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="{Binding TitleFontSize}"
                                   FontWeight="{Binding TitleFontWeight}"
                                   Foreground="{Binding TitleColor, Converter={StaticResource ColorToBrush}}"
                                   Visibility="{Binding ShowNotificationTitle, Converter={StaticResource BoolToVis}}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Hey, are you available for a quick call about the project?"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="{Binding FontSize}"
                                   FontWeight="{Binding FontWeight}"
                                   Foreground="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                                   Visibility="{Binding ShowNotificationBody, Converter={StaticResource BoolToVis}}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="2m ago"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="{Binding TimestampFontSize}"
                                   FontWeight="{Binding TimestampFontWeight}"
                                   Foreground="{Binding TimestampColor, Converter={StaticResource ColorToBrush}}"
                                   Visibility="{Binding ShowTimestamp, Converter={StaticResource BoolToVis}}"
                                   Opacity="0.8"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Border>

        <!-- Tabs -->
        <TabControl x:Name="MainTabControl" Grid.Row="3" Style="{StaticResource SettingsTabControl}" Margin="20,12,20,8"
                    AutomationProperties.Name="Settings categories"
                    KeyboardNavigation.TabNavigation="Cycle">

            <!-- ═══ PROFILES TAB ═══ -->
            <!-- ═══ APPEARANCE TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Appearance settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- palette -->
                        <Viewbox Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                <Ellipse Canvas.Left="13" Canvas.Top="6" Width="2" Height="2" Fill="{DynamicResource TextPrimaryBrush}"/>
                                <Ellipse Canvas.Left="17" Canvas.Top="10" Width="2" Height="2" Fill="{DynamicResource TextPrimaryBrush}"/>
                                <Ellipse Canvas.Left="6" Canvas.Top="12" Width="2" Height="2" Fill="{DynamicResource TextPrimaryBrush}"/>
                                <Ellipse Canvas.Left="8" Canvas.Top="7" Width="2" Height="2" Fill="{DynamicResource TextPrimaryBrush}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Appearance"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <!-- OVERLAY THEMES section -->
                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="OVERLAY THEMES" Style="{StaticResource SectionHeader}"
                                       ToolTip="Quickly style notification cards. These theme presets affect the overlay. UI Styling controls settings-window colors."/>
                        </Border>

                        <DockPanel Margin="0,4,0,0">
                            <Button DockPanel.Dock="Right" Content="Apply" Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0" Command="{Binding ApplySelectedBuiltInThemeCommand}"
                                    ToolTip="Apply the selected built-in theme to the overlay"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                      ItemsSource="{Binding BuiltInThemes}"
                                      SelectedItem="{Binding SelectedBuiltInTheme}"
                                      ToolTip="Choose a built-in overlay theme">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="12" Height="12" CornerRadius="2"
                                                    Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="CUSTOM OVERLAY THEMES" Style="{StaticResource SectionHeader}"
                                       ToolTip="Save your current overlay look, then re-apply it anytime."/>
                        </Border>

                        <DockPanel Margin="0,4,0,8">
                            <Button DockPanel.Dock="Right" Content="Save" Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0" Command="{Binding SaveCustomThemeCommand}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewThemeName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter a name for the custom overlay theme"/>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding CustomThemes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="Delete" Style="{StaticResource SecondaryButton}"
                                                Width="72" Padding="0" Margin="4,0,0,0"
                                                Command="{Binding DataContext.DeleteCustomThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Name}"
                                                ToolTip="Delete this custom theme"/>
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Padding="10,6" HorizontalContentAlignment="Left"
                                                Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Apply this custom theme">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="14" Height="14" CornerRadius="3"
                                                        Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                                                        Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No custom themes saved yet."
                                   Style="{StaticResource SettingDesc}" Margin="0,4,0,0"
                                   Visibility="{Binding CustomThemes.Count, Converter={StaticResource ZeroToVisible}}"/>

                        <!-- THEME SCHEDULE section -->
                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="THEME SCHEDULE" Style="{StaticResource SectionHeader}"
                                       ToolTip="Automatically switch overlay themes based on time of day"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ThemeScheduleEnabled}"
                                          ToolTip="Enable automatic theme switching at scheduled times"/>
                            <TextBlock Text="Enable Theme Schedule" Style="{StaticResource SettingLabel}"
                                       ToolTip="Automatically switch between day and night themes at the configured times"/>
                        </DockPanel>

                        <TextBlock Text="Day Theme" Style="{StaticResource SettingLabel}"
                                   ToolTip="Theme to apply during daytime hours"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableSettingsThemeModes}"
                                  SelectedItem="{Binding DayThemeName}"
                                  Margin="0,4,0,4"
                                  ToolTip="Select the theme for daytime"/>

                        <TextBlock Text="Night Theme" Style="{StaticResource SettingLabel}"
                                   ToolTip="Theme to apply during nighttime hours"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableSettingsThemeModes}"
                                  SelectedItem="{Binding NightThemeName}"
                                  Margin="0,4,0,4"
                                  ToolTip="Select the theme for nighttime"/>

                        <UniformGrid Columns="2" Margin="0,4,0,8">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Day Start (HH:mm)" Style="{StaticResource SettingLabel}"
                                           ToolTip="Time when the day theme activates (24-hour format)"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding DayStartTime, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Enter time in 24-hour format, e.g. 07:00"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Night Start (HH:mm)" Style="{StaticResource SettingLabel}"
                                           ToolTip="Time when the night theme activates (24-hour format)"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding NightStartTime, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Enter time in 24-hour format, e.g. 19:00"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- TYPOGRAPHY section -->
                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="TYPOGRAPHY" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <TextBlock Text="Font Family" Style="{StaticResource SettingLabel}" ToolTip="Typeface used for all notification text in the overlay"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding FontFamily}"
                                  ToolTip="The typeface used for notification text"
                                  Margin="0,4,0,0"/>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="OpenDyslexic" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,4"
                                    Command="{Binding SetFontPresetCommand}" CommandParameter="pack://application:,,,/Fonts/#OpenDyslexic"
                                    ToolTip="Apply OpenDyslexic — a font designed for readers with dyslexia"/>
                            <Button Content="Segoe UI (Default)" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,4"
                                    Command="{Binding SetFontPresetCommand}" CommandParameter="Segoe UI"
                                    ToolTip="Reset to the default Windows font"/>
                        </WrapPanel>

                        <TextBlock Text="Body Font Size" Style="{StaticResource SettingLabel}" ToolTip="Size of the notification body text"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding FontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="56" Value="{Binding FontSize}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Controls body text size"/>
                        </DockPanel>

                        <TextBlock Text="Body Font Weight" Style="{StaticResource SettingLabel}" ToolTip="Thickness of the notification body text"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFontWeights}"
                                  SelectedItem="{Binding FontWeight}"
                                  ToolTip="How bold or light the notification body text appears"
                                  Margin="0,4,0,0"/>

                        <TextBlock Text="App Name Font Size" Style="{StaticResource SettingLabel}" ToolTip="Size of the source app name line (Teams, Slack, etc.)"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding AppNameFontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="56" Value="{Binding AppNameFontSize}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Controls the size of app name text"/>
                        </DockPanel>

                        <TextBlock Text="App Name Font Weight" Style="{StaticResource SettingLabel}" ToolTip="Thickness of the source app name text"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFontWeights}"
                                  SelectedItem="{Binding AppNameFontWeight}"
                                  ToolTip="How bold the app name text appears"
                                  Margin="0,4,0,0"/>

                        <TextBlock Text="Title Font Size" Style="{StaticResource SettingLabel}" ToolTip="Size of the notification title line"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding TitleFontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="56" Value="{Binding TitleFontSize}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Controls the size of notification title text"/>
                        </DockPanel>

                        <TextBlock Text="Title Font Weight" Style="{StaticResource SettingLabel}" ToolTip="Thickness of the notification title text"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFontWeights}"
                                  SelectedItem="{Binding TitleFontWeight}"
                                  ToolTip="How bold the title text appears"
                                  Margin="0,4,0,0"/>

                        <TextBlock Text="Line Spacing" Style="{StaticResource SettingLabel}" ToolTip="More spacing makes dense notifications easier to scan"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}"
                                       Text="{Binding LineSpacing, StringFormat='{}{0:0.0}'}"/>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1.0" Maximum="2.5" Value="{Binding LineSpacing}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    ToolTip="Space between lines of text — increase for readability"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="TIMESTAMP APPEARANCE" Style="{StaticResource SectionHeader}"
                                       ToolTip="Control how timestamp text looks. Timestamp visibility is toggled in Behavior &gt; Content."/>
                        </Border>

                        <StackPanel IsEnabled="{Binding ShowTimestamp}">
                            <TextBlock Text="Timestamp Style" Style="{StaticResource SettingLabel}" ToolTip="Relative: '2m ago'. Time: '14:35'. DateTime: localized date and time."/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                      ItemsSource="{Binding AvailableTimestampDisplayModes}"
                                      SelectedItem="{Binding TimestampDisplayMode}"
                                      Margin="0,4,0,0"
                                      ToolTip="Relative shows '2m ago'. Time shows clock time. DateTime shows date and time."/>

                            <TextBlock Text="Timestamp Size" Style="{StaticResource SettingLabel}" ToolTip="Increase for readability on larger displays, or reduce for compact layouts."/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding TimestampFontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="8" Maximum="32" Value="{Binding TimestampFontSize}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ToolTip="Font size for timestamp text on each notification card"/>
                            </DockPanel>

                            <TextBlock Text="Timestamp Font Weight" Style="{StaticResource SettingLabel}" ToolTip="Use medium or semibold for stronger readability in busy overlays."/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                      ItemsSource="{Binding AvailableFontWeights}"
                                      SelectedItem="{Binding TimestampFontWeight}"
                                      Margin="0,4,0,0"
                                      ToolTip="Choose how bold timestamp text appears on each card."/>

                            <TextBlock Text="Timestamp Color" Style="{StaticResource SettingLabel}" ToolTip="Adjust timestamp contrast independently from app/title/body text colors."/>
                            <DockPanel Margin="0,4,0,4">
                                <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding TimestampColor, Converter={StaticResource ColorToBrush}}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                                <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                        Margin="8,0,0,0"
                                        Tag="TimestampColor" Click="OnPickColorClick"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding TimestampColor, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="7"/>
                            </DockPanel>
                        </StackPanel>

                        <!-- COLORS section -->
                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="COLORS" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <TextBlock Text="Title Color" Style="{StaticResource SettingLabel}" ToolTip="Color of the notification title text"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding TitleColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="TitleColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for notification title text"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding TitleColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for notification titles (e.g. #FFFFFF)"
                                     MaxLength="7"/>
                        </DockPanel>

                        <TextBlock Text="App Name Color" Style="{StaticResource SettingLabel}" ToolTip="Color used for the source app line (Teams, Slack, Outlook, etc.)"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding AppNameColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="AppNameColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for app-name text"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding AppNameColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for source app names (e.g. #C8C8C8)"
                                     MaxLength="7"/>
                        </DockPanel>

                        <TextBlock Text="Body Text Color" Style="{StaticResource SettingLabel}" ToolTip="Color of the notification body content"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="TextColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for notification body text"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for notification body text (e.g. #E6E6E6)"
                                     MaxLength="7"/>
                        </DockPanel>

                        <TextBlock Text="Background Color" Style="{StaticResource SettingLabel}" ToolTip="Background of each notification card"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="BackgroundColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for card background"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for the notification card background"
                                     MaxLength="7"/>
                        </DockPanel>

                        <TextBlock Text="Accent Color" Style="{StaticResource SettingLabel}" ToolTip="Colored stripe on the left edge of each notification card"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="AccentColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for accent stripe"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for the left accent stripe on notification cards"
                                     MaxLength="7"/>
                        </DockPanel>

                        <TextBlock Text="Background Opacity" Style="{StaticResource SettingLabel}" ToolTip="Lower values make cards more transparent so you can see through them"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}"
                                       Text="{Binding BackgroundOpacity, StringFormat='{}{0:P0}'}"/>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0.1" Maximum="1.0" Value="{Binding BackgroundOpacity}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    ToolTip="How transparent the notification background appears"/>
                        </DockPanel>

                        <!-- SHAPE section -->
                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SHAPE" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <TextBlock Text="Corner Radius" Style="{StaticResource SettingLabel}" ToolTip="0 for sharp corners, higher values for rounder cards"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding CornerRadius, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="24" Value="{Binding CornerRadius}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Roundness of notification card corners"/>
                        </DockPanel>

                        <TextBlock Text="Padding" Style="{StaticResource SettingLabel}" ToolTip="Space between the card edge and the notification text"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding Padding, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="4" Maximum="32" Value="{Binding Padding}"
                                    TickFrequency="2" IsSnapToTickEnabled="True"
                                    ToolTip="Internal spacing between card edge and text"/>
                        </DockPanel>

                        <TextBlock Text="Card Gap" Style="{StaticResource SettingLabel}" ToolTip="Vertical space between each notification card"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding CardGap, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="24" Value="{Binding CardGap}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Vertical spacing between notification cards"/>
                        </DockPanel>

                        <TextBlock Text="Outer Margin" Style="{StaticResource SettingLabel}" ToolTip="Space around the entire card area inside the overlay window"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OuterMargin, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="24" Value="{Binding OuterMargin}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Margin around the card area within the overlay"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="ACCENT STRIPE" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowAccent}"
                                          ToolTip="Show or hide the colored accent stripe on the left edge of cards"/>
                            <TextBlock Text="Show Accent Stripe" Style="{StaticResource SettingLabel}" ToolTip="Colored bar on the left edge of each notification card"/>
                        </DockPanel>

                        <TextBlock Text="Accent Thickness" Style="{StaticResource SettingLabel}" ToolTip="Width of the left accent stripe in pixels"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding AccentThickness, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1" Maximum="8" Value="{Binding AccentThickness}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Width of the accent stripe on each card"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="CARD BORDER" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowBorder}"
                                          ToolTip="Show or hide a border around each notification card"/>
                            <TextBlock Text="Show Card Border" Style="{StaticResource SettingLabel}" ToolTip="Adds a subtle border around each notification card"/>
                        </DockPanel>

                        <TextBlock Text="Border Color" Style="{StaticResource SettingLabel}" ToolTip="Color of the border around notification cards"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding BorderColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="BorderColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for card border"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding BorderColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for the card border (e.g. #3A3A3A)"
                                     MaxLength="7"/>
                        </DockPanel>

                        <TextBlock Text="Border Thickness" Style="{StaticResource SettingLabel}" ToolTip="Width of the border around each card in pixels"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding BorderThickness, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1" Maximum="4" Value="{Binding BorderThickness}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Thickness of the card border"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="NOTIFICATION ICONS" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Show Icons" Style="{StaticResource SettingLabel}"/>
                            <ToggleButton DockPanel.Dock="Right" HorizontalAlignment="Right"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowNotificationIcons}"
                                          ToolTip="Show an icon next to each notification card"/>
                        </DockPanel>

                        <TextBlock Text="Icon Size" Style="{StaticResource SettingLabel}" ToolTip="Controls the size of icons displayed next to notifications"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding IconSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="16" Maximum="48" Value="{Binding IconSize}"
                                    TickFrequency="4" IsSnapToTickEnabled="True"
                                    ToolTip="Size of the notification icon in pixels"/>
                        </DockPanel>

                        <TextBlock Text="Default Icon" Style="{StaticResource SettingLabel}" ToolTip="Choose a built-in icon shape for all notifications. Per-app overrides can be configured in the Filtering tab."/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableIconPresets}"
                                  SelectedItem="{Binding DefaultIconPreset}"
                                  Margin="0,4,0,0"
                                  ToolTip="Built-in icon preset shown for all apps unless overridden"/>

                        <Button Content="Browse Custom Icon..." Style="{StaticResource SecondaryButton}"
                                Margin="0,0,0,4" HorizontalAlignment="Left"
                                Command="{Binding BrowseCustomIconCommand}"
                                ToolTip="Import a custom image file as a notification icon (PNG/JPG/ICO)"/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="OVERLAY SCROLLBAR" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Show Scrollbar" Style="{StaticResource SettingLabel}"/>
                            <ToggleButton DockPanel.Dock="Right" HorizontalAlignment="Right"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding OverlayScrollbarVisible}"
                                          ToolTip="Show or hide the overlay scrollbar when notifications overflow"/>
                        </DockPanel>

                        <TextBlock Text="Scrollbar Width" Style="{StaticResource SettingLabel}" ToolTip="Controls how wide the scrollbar appears in the overlay"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OverlayScrollbarWidth, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="4" Maximum="20" Value="{Binding OverlayScrollbarWidth}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Width of the overlay scrollbar in pixels"/>
                        </DockPanel>

                        <TextBlock Text="Scrollbar Opacity" Style="{StaticResource SettingLabel}" ToolTip="Controls the transparency of the scrollbar"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OverlayScrollbarOpacity, StringFormat='{}{0:P0}'}"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0.1" Maximum="1.0" Value="{Binding OverlayScrollbarOpacity}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    ToolTip="Opacity of the overlay scrollbar"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="FULLSCREEN OVERLAY" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding FullscreenOverlayMode}"
                                          ToolTip="Expand overlay to fill the entire screen"/>
                            <TextBlock Text="Fullscreen Mode" Style="{StaticResource SettingLabel}"
                                       ToolTip="Expands the overlay background to fill your screen with a configurable backdrop for dedicated notification monitoring. If fullscreen appears slightly short, increase Overlay Max Height in Layout until the overlay fully matches your screen."/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding FullscreenOverlayMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Background Color" Style="{StaticResource SettingLabel}" ToolTip="Background color for the fullscreen overlay backdrop"/>
                            <DockPanel Margin="0,4,0,0">
                                <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding FullscreenOverlayColor, Converter={StaticResource ColorToBrush}}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Margin="0,0,8,0"/>
                                <Button DockPanel.Dock="Right" Content="Pick"
                                        Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                        Tag="FullscreenOverlayColor" Click="OnPickColorClick"
                                        ToolTip="Pick a background color for fullscreen overlay"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding FullscreenOverlayColor, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Hex color for the fullscreen overlay background"
                                         MaxLength="7"/>
                            </DockPanel>

                            <TextBlock Text="Background Opacity" Style="{StaticResource SettingLabel}" ToolTip="Controls how opaque the fullscreen backdrop appears"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding FullscreenOverlayOpacity, StringFormat='{}{0:P0}'}"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="0.1" Maximum="1.0" Value="{Binding FullscreenOverlayOpacity}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        ToolTip="How opaque the fullscreen background is"/>
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ BEHAVIOR TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Behavior settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- settings -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z" />
                        <TextBlock Text="Behavior"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="TIMING" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <TextBlock Text="Notification Duration" Style="{StaticResource SettingLabel}" ToolTip="Seconds each notification remains on screen before auto-dismissing"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding NotificationDuration, StringFormat='{}{0:0}'}"/><Run Text="s"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="2" Maximum="120" Value="{Binding NotificationDuration}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="How long each notification stays visible before fading out"/>
                        </DockPanel>

                        <TextBlock Text="Visible Notifications" Style="{StaticResource SettingLabel}" ToolTip="Default is 15. Lower counts reduce noise; higher counts keep more recent context visible."/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding MaxVisibleNotifications, StringFormat='{}{0:0}'}"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1" Maximum="40" Value="{Binding MaxVisibleNotifications}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Maximum number of notification cards shown at once"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="CONTENT" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowAppName}"
                                          ToolTip="Display the source app name on each card"/>
                            <TextBlock Text="Show App Name" Style="{StaticResource SettingLabel}" ToolTip="Useful when multiple apps notify at once and you need source context quickly"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowNotificationTitle}"
                                          ToolTip="Display the notification title line"/>
                            <TextBlock Text="Show Title" Style="{StaticResource SettingLabel}" ToolTip="Primary headline line from each notification"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowNotificationBody}"
                                          ToolTip="Display the notification body content"/>
                            <TextBlock Text="Show Body Text" Style="{StaticResource SettingLabel}" ToolTip="Long-form notification content; automatically kept on if all fields are turned off"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowTimestamp}"
                                          ToolTip="Show timestamp text on each notification card"/>
                            <TextBlock Text="Show Timestamp" Style="{StaticResource SettingLabel}" ToolTip="Show when each notification arrived. Configure timestamp style and color in Appearance &gt; Timestamp Appearance."/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding IsStackedLayout, Converter={StaticResource BoolToVis}}">
                            <DockPanel Margin="0,0,0,8">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NewestOnTop}"
                                              ToolTip="When on, newest notifications appear first at the top. Turn off for chronological top-to-bottom flow."/>
                                <TextBlock Text="Newest on Top" Style="{StaticResource SettingLabel}" ToolTip="Turn off to let new notifications appear underneath older ones."/>
                            </DockPanel>

                            <DockPanel Margin="0,0,0,8">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding GroupByApp}"
                                              ToolTip="Group notifications under app name headers in the overlay"/>
                                <TextBlock Text="Group Notifications by App" Style="{StaticResource SettingLabel}"
                                           ToolTip="When enabled, notifications from the same app are grouped under a shared header"/>
                            </DockPanel>

                            <DockPanel Margin="0,0,0,8">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding LimitTextLines}"
                                              ToolTip="Limit text height and truncate long notifications with ellipsis"/>
                                <TextBlock Text="Limit Text Lines (Truncate)" Style="{StaticResource SettingLabel}" ToolTip="Turn this off for full multi-line word wrap with no truncation in stacked mode"/>
                            </DockPanel>

                            <StackPanel Margin="12,0,0,0" Visibility="{Binding LimitTextLines, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="App Name Max Lines" Style="{StaticResource SettingLabel}" ToolTip="Limit source app text height before truncation in stacked mode"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                        <Run Text="{Binding MaxAppNameLines, StringFormat='{}{0:0}'}"/>
                                    </TextBlock>
                                    <Slider Style="{StaticResource SettingsSlider}"
                                            Minimum="1" Maximum="4" Value="{Binding MaxAppNameLines}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ToolTip="Maximum displayed lines for app-name text in stacked mode"/>
                                </DockPanel>

                                <TextBlock Text="Title Max Lines" Style="{StaticResource SettingLabel}" ToolTip="Keeps title cards compact while still showing key context"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                        <Run Text="{Binding MaxTitleLines, StringFormat='{}{0:0}'}"/>
                                    </TextBlock>
                                    <Slider Style="{StaticResource SettingsSlider}"
                                            Minimum="1" Maximum="6" Value="{Binding MaxTitleLines}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ToolTip="Maximum displayed lines for notification titles in stacked mode"/>
                                </DockPanel>

                                <TextBlock Text="Body Max Lines" Style="{StaticResource SettingLabel}" ToolTip="Controls how much message text is shown before truncating with ellipsis"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                        <Run Text="{Binding MaxBodyLines, StringFormat='{}{0:0}'}"/>
                                    </TextBlock>
                                    <Slider Style="{StaticResource SettingsSlider}"
                                            Minimum="1" Maximum="10" Value="{Binding MaxBodyLines}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ToolTip="Maximum displayed lines for notification body text in stacked mode"/>
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SingleLineMode}"
                                          ToolTip="Render each notification as a single horizontal banner line"/>
                            <TextBlock Text="Single-Line Banner Mode" Style="{StaticResource SettingLabel}" ToolTip="Compacts notifications into one line per card. Turn off for stacked multi-line cards."/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding SingleLineMode, Converter={StaticResource BoolToVis}}">
                            <DockPanel Margin="0,0,0,8">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding SingleLineWrapText}"
                                              ToolTip="Allow one-line banner content to wrap instead of truncating"/>
                                <TextBlock Text="Wrap Banner Text" Style="{StaticResource SettingLabel}" ToolTip="Useful on smaller monitors: preserves content by wrapping onto additional lines."/>
                            </DockPanel>

                            <TextBlock Text="Banner Max Lines" Style="{StaticResource SettingLabel}" ToolTip="Lower values keep more cards visible at once; higher values show more text per card."/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding SingleLineMaxLines, StringFormat='{}{0:0}'}"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="1" Maximum="12" Value="{Binding SingleLineMaxLines}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ToolTip="Maximum wrapped lines per banner card in single-line mode"/>
                            </DockPanel>

                            <DockPanel Margin="0,0,0,8">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding SingleLineAutoFullWidth}"
                                              ToolTip="Automatically expand banner width to near full monitor width"/>
                                <TextBlock Text="Auto Full-Width Banner" Style="{StaticResource SettingLabel}" ToolTip="When enabled, single-line mode spans almost the full monitor width automatically."/>
                            </DockPanel>

                            <DockPanel Margin="0,0,0,8">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding SingleLineReplaceMode}"
                                              ToolTip="New notifications replace the current one instead of stacking"/>
                                <TextBlock Text="Replace Mode" Style="{StaticResource SettingLabel}"
                                           ToolTip="When enabled, each new notification replaces all current ones (useful for live tickers or latest-only display)"/>
                            </DockPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="WINDOW" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AlwaysOnTop}"
                                          ToolTip="Keep the overlay above all other windows"/>
                            <TextBlock Text="Always on Top" Style="{StaticResource SettingLabel}" ToolTip="When enabled, the overlay floats above all other windows including full-screen apps"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ClickThrough}"
                                          ToolTip="Allow mouse clicks to pass through the overlay"/>
                            <TextBlock Text="Click-Through Mode" Style="{StaticResource SettingLabel}" ToolTip="Mouse clicks pass through the overlay so you can interact with windows behind it. Disable to drag/resize the overlay."/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="ANIMATIONS" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AnimationsEnabled}"
                                          ToolTip="Enable or disable slide and fade animations"/>
                            <TextBlock Text="Enable Animations" Style="{StaticResource SettingLabel}" ToolTip="Smooth slide-in and fade-out transitions for notifications"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding FadeOnlyAnimation}"
                                          ToolTip="Use fade transitions only (no side movement)"/>
                            <TextBlock Text="Fade-Only Animation" Style="{StaticResource SettingLabel}" ToolTip="Useful if motion is distracting or you prefer a calmer transition style"/>
                        </DockPanel>

                        <TextBlock Text="Slide-In Direction" Style="{StaticResource SettingLabel}" ToolTip="Direction notifications slide in from (overridden when fade-only is enabled)"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableSlideDirections}"
                                  SelectedItem="{Binding SlideInDirection}"
                                  ToolTip="Which direction cards slide in from"
                                  Margin="0,4,0,0"/>

                        <TextBlock Text="Animation Speed" Style="{StaticResource SettingLabel}" ToolTip="0 means instant transitions; higher values feel smoother"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding AnimationDurationMs, StringFormat='{}{0:0}'}"/><Run Text="ms"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="1200" Value="{Binding AnimationDurationMs}"
                                    TickFrequency="25" IsSnapToTickEnabled="True"
                                    ToolTip="Duration of slide/fade animations in milliseconds"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="DEDUPLICATION" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding DeduplicationEnabled}"
                                          ToolTip="Skip duplicate notifications that arrive within the dedup window"/>
                            <TextBlock Text="Deduplicate Notifications" Style="{StaticResource SettingLabel}" ToolTip="Suppresses identical notifications that arrive in quick succession"/>
                        </DockPanel>

                        <TextBlock Text="Dedup Window" Style="{StaticResource SettingLabel}" ToolTip="How long (in seconds) to consider identical notifications as duplicates"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding DeduplicationWindowSeconds, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0.5" Maximum="10" Value="{Binding DeduplicationWindowSeconds}"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    ToolTip="Time window for considering notifications as duplicates"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SYSTEM NOTIFICATIONS" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SuppressToastPopups}"
                                          ToolTip="Suppression is only active while Notifications Pro is running. Closing the app immediately restores normal toast behavior."/>
                            <TextBlock Text="Suppress Toast Popups" Style="{StaticResource SettingLabel}"
                                       ToolTip="Removes Windows toast popups after capture to prevent duplicates on screen. Also removes notifications from Windows notification center. Only works with WinRT capture mode (not accessibility fallback). Suppression stops immediately when the app closes."/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SESSION ARCHIVE" Style="{StaticResource SectionHeader}"
                                       ToolTip="Keep a temporary record of notifications received this session. RAM only — never saved to disk, cleared when the app closes."/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SessionArchiveEnabled}"
                                          ToolTip="When enabled, notifications are kept in memory for the duration of this session. Data is never written to disk and is cleared when the app closes."/>
                            <TextBlock Text="Enable Session Archive" Style="{StaticResource SettingLabel}"
                                       ToolTip="Temporarily stores notification text in RAM so you can review missed notifications. Never persisted to disk. Cleared on app close."/>
                        </DockPanel>

                        <TextBlock Text="Max archive items" Style="{StaticResource SettingLabel}"
                                   ToolTip="Maximum number of notifications to keep in the session archive (10-1000). Oldest entries are removed when the limit is reached."/>
                        <Slider Minimum="10" Maximum="1000" TickFrequency="10"
                                Value="{Binding SessionArchiveMaxItems}"
                                Style="{StaticResource SettingsSlider}" Margin="0,4,0,0"/>

                        <Button Content="View Archive (Copy to Clipboard)" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ViewSessionArchiveCommand}"
                                Margin="0,8,0,0" HorizontalAlignment="Left"
                                ToolTip="Copies all archived notifications to the clipboard. Data exists only in RAM."/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ FILTERING TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Filtering settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- filter -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M10 20a1 1 0 0 0 .553.895l2 1A1 1 0 0 0 14 21v-7a2 2 0 0 1 .517-1.341L21.74 4.67A1 1 0 0 0 21 3H3a1 1 0 0 0-.742 1.67l7.225 7.989A2 2 0 0 1 10 14z" />
                        <TextBlock Text="Filtering"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="PER-APP MUTING" Style="{StaticResource SectionHeader}"
                                       ToolTip="Apps seen this session appear below. Toggle to mute/unmute."/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding MutedAppEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="{Binding IsMuted, Converter={StaticResource BoolToMuteLabel}}"
                                                Style="{StaticResource SecondaryButton}" Width="72" Padding="0"
                                                Command="{Binding DataContext.ToggleMuteAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding AppName}"/>
                                        <TextBlock Text="{Binding AppName}" Style="{StaticResource SettingLabel}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No apps seen yet — notifications will populate this list"
                                   Style="{StaticResource SettingDesc}" Margin="0,4,0,0"
                                   Visibility="{Binding MutedAppEntries.Count, Converter={StaticResource ZeroToVisible}}"/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="KEYWORD HIGHLIGHTING" Style="{StaticResource SectionHeader}"
                                       ToolTip="Notifications matching these keywords get a colored accent stripe."/>
                        </Border>

                        <TextBlock Text="Default highlight color" Style="{StaticResource SettingLabel}" ToolTip="Default accent color applied to new keywords. Each keyword can have its own color."/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            
                            <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding HighlightColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color used as default for new keywords"
                                     MaxLength="7" Margin="0,0,8,0"/>
                                     
                            <Button Grid.Column="2" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" MinHeight="36"
                                    Tag="HighlightColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for the default highlight color"/>
                        </Grid>

                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox Grid.Column="0" Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewHighlightKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Type a keyword and press Add" Margin="0,0,8,0"/>
                                     
                            <Button Grid.Column="1" Content="Add Keyword" Style="{StaticResource SecondaryButton}"
                                    MinWidth="110" Command="{Binding AddHighlightKeywordCommand}"
                                    ToolTip="Add the entered keyword to highlight matching notifications"/>
                        </Grid>
                        
                        <ItemsControl ItemsSource="{Binding HighlightKeywordEntries}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="Remove" Style="{StaticResource SecondaryButton}"
                                                Width="72" Padding="0"
                                                Command="{Binding DataContext.RemoveHighlightKeywordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove this highlight keyword"/>
                                        <Button DockPanel.Dock="Right" Content="Color" Style="{StaticResource SecondaryButton}"
                                                Width="56" Padding="0" Margin="0,0,4,0"
                                                Click="OnPickKeywordColorClick"
                                                ToolTip="Pick a custom highlight color for this keyword"/>
                                        <Border DockPanel.Dock="Right" Width="24" Height="24" CornerRadius="4"
                                                Background="{Binding Color, Converter={StaticResource ColorToBrush}}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <ToggleButton DockPanel.Dock="Right" Content=".*" IsChecked="{Binding IsRegex}"
                                                      Background="{DynamicResource SurfaceLightBrush}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                      Width="36" Padding="0" Margin="0,0,4,0"
                                                      ToolTip="Toggle regex mode — when enabled, the keyword is treated as a regular expression pattern"/>
                                        <TextBlock Text="{Binding Keyword}" Style="{StaticResource SettingLabel}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="KEYWORD MUTING" Style="{StaticResource SectionHeader}"
                                       ToolTip="Notifications containing these keywords will be silently suppressed."/>
                        </Border>

                        <DockPanel Margin="0,4,0,8">
                            <Button DockPanel.Dock="Right" Content="Add Keyword" Style="{StaticResource SecondaryButton}"
                                    MinWidth="110" Margin="8,0,0,0" Command="{Binding AddMuteKeywordCommand}"
                                    ToolTip="Add the entered keyword to suppress matching notifications"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewMuteKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Type a keyword and press Add"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding MuteKeywordEntries}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="Remove" Style="{StaticResource SecondaryButton}"
                                                Width="72" Padding="0"
                                                Command="{Binding DataContext.RemoveMuteKeywordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove this mute keyword"/>
                                        <ToggleButton DockPanel.Dock="Right" Content=".*" IsChecked="{Binding IsRegex}"
                                                      Background="{DynamicResource SurfaceLightBrush}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                      Width="36" Padding="0" Margin="0,0,4,0"
                                                      ToolTip="Toggle regex mode — when enabled, the keyword is treated as a regular expression pattern"/>
                                        <TextBlock Text="{Binding Keyword}" Style="{StaticResource SettingLabel}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="PER-APP SOUNDS &amp; ICONS" Style="{StaticResource SectionHeader}"
                                       ToolTip="Assign individual sounds and icons per app. 'Default' uses the global setting."/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding PerAppConfigEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,0,0,6"
                                            CornerRadius="6" Background="{DynamicResource SurfaceLightBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding AppName}" Style="{StaticResource SettingLabel}"
                                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sound" Style="{StaticResource SettingLabel}"
                                                           Margin="0,0,8,8" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsComboBox}"
                                                          ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                                          ItemsSource="{Binding DataContext.PerAppSoundOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedValuePath="WavPath"
                                                          SelectedValue="{Binding Sound}"
                                                          Margin="0,0,0,8">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource UIFont}" FontSize="13"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Icon" Style="{StaticResource SettingLabel}"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsComboBox}"
                                                          ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                                          ItemsSource="{Binding DataContext.PerAppIconOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding Icon}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No apps seen yet — notifications will populate this list"
                                   Style="{StaticResource SettingDesc}" Margin="0,4,0,0"
                                   Visibility="{Binding PerAppConfigEntries.Count, Converter={StaticResource ZeroToVisible}}"/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="QUIET HOURS" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding QuietHoursEnabled}"
                                          ToolTip="Automatically suppress notifications during specified hours"/>
                            <TextBlock Text="Enable Quiet Hours" Style="{StaticResource SettingLabel}" ToolTip="Silences all notifications between the start and end times"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding QuietHoursEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Start Time (HH:mm)" Style="{StaticResource SettingLabel}" ToolTip="e.g. 22:00 for 10 PM"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding QuietHoursStart, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Time to begin suppressing notifications (24h format)"
                                     MaxLength="5"/>

                            <TextBlock Text="End Time (HH:mm)" Style="{StaticResource SettingLabel}" ToolTip="e.g. 08:00 for 8 AM"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding QuietHoursEnd, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Time to stop suppressing notifications (24h format)"
                                     MaxLength="5"/>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="BURST LIMITING" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding BurstLimitEnabled}"
                                          ToolTip="Auto-suppress when too many notifications arrive in a short window"/>
                            <TextBlock Text="Enable Burst Limiting" Style="{StaticResource SettingLabel}" ToolTip="Prevents notification storms from flooding the overlay"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding BurstLimitEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Max Notifications" Style="{StaticResource SettingLabel}" ToolTip="Number of notifications allowed before suppression kicks in"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding BurstLimitCount, StringFormat='{}{0:0}'}"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="2" Maximum="50" Value="{Binding BurstLimitCount}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ToolTip="Max notifications allowed within the burst window"/>
                            </DockPanel>

                            <TextBlock Text="Burst Window" Style="{StaticResource SettingLabel}" ToolTip="How many seconds to count notifications over"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding BurstLimitWindowSeconds, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="1" Maximum="30" Value="{Binding BurstLimitWindowSeconds}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ToolTip="Time window in seconds for burst detection"/>
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ LAYOUT TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Layout settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- layout-template -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M4 3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H4zm-1 11a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-6zm13-1a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-6a1 1 0 0 0-1-1h-3z" />
                        <TextBlock Text="Layout"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="MONITOR" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <TextBlock Text="Target Monitor" Style="{StaticResource SettingLabel}" ToolTip="Choose a monitor, then click Move to reposition the overlay. Position presets also use this monitor."/>
                        <ComboBox Style="{StaticResource SettingsComboBox}" Margin="0,4,0,6"
                                  ItemsSource="{Binding MonitorItems}"
                                  SelectedIndex="{Binding SelectedMonitorIndex}"
                                  ToolTip="Select which monitor the overlay should appear on"/>
                        <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,4">
                            <Button Content="Refresh Monitors" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshMonitorsCommand}" Margin="0,0,8,8"
                                    ToolTip="Re-detect connected monitors"/>
                            <Button Content="Move Overlay" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding MoveToMonitorCommand}" Margin="0,0,0,8"
                                    ToolTip="Move the overlay to the selected monitor"/>
                        </WrapPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="QUICK POSITION" Style="{StaticResource SectionHeader}"
                                       ToolTip="Move overlay to common positions on the selected monitor."/>
                        </Border>
                        <UniformGrid Columns="3" Margin="0,4,0,0">
                            <Button Content="Top Left" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="top-left"/>
                            <Button Content="Top Center" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="top-center"/>
                            <Button Content="Top Right" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="top-right"/>
                            <Button Content="Middle Left" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="middle-left"/>
                            <Button Content="Middle Center" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="middle-center"/>
                            <Button Content="Middle Right" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="middle-right"/>
                            <Button Content="Bottom Left" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="bottom-left"/>
                            <Button Content="Bottom Center" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="bottom-center"/>
                            <Button Content="Bottom Right" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="bottom-right"/>
                        </UniformGrid>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="OVERLAY SIZE" Style="{StaticResource SectionHeader}"
                                       ToolTip="Configure overlay width, height limits, and quick presets."/>
                        </Border>

                        <TextBlock Text="Overlay Width" Style="{StaticResource SettingLabel}" ToolTip="Wider overlays show more text per line and work best with single-line mode"/>
                        <DockPanel Margin="0,4,0,0">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBox Style="{StaticResource SettingsTextBox}" Width="90"
                                         Margin="8,0,0,0" VerticalAlignment="Center"
                                         Text="{Binding OverlayWidth, UpdateSourceTrigger=LostFocus, StringFormat='{}{0:0}'}"
                                         ToolTip="Type exact width in pixels (220-7680)"/>
                                <TextBlock Style="{StaticResource SliderValue}" VerticalAlignment="Center"
                                           Margin="4,0,0,0" Text="px"/>
                            </StackPanel>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="220" Maximum="7680" Value="{Binding OverlayWidth}"
                                    TickFrequency="20" IsSnapToTickEnabled="True"
                                    ToolTip="Width of the overlay window in pixels"/>
                        </DockPanel>

                        <TextBlock Text="Width Presets" Style="{StaticResource SettingLabel}" ToolTip="Quickly set width targets for common display classes."/>
                        <UniformGrid Columns="4" Margin="0,4,0,8">
                            <Button Content="1080p" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="1080p"/>
                            <Button Content="2K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="2k"/>
                            <Button Content="4K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="4k"/>
                            <Button Content="8K" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="8k"/>
                        </UniformGrid>

                        <TextBlock Text="Max Overlay Height" Style="{StaticResource SettingLabel}" ToolTip="The overlay expands vertically as needed up to this limit, then scrolls. If long stacked notifications appear cut off, increase this value or scroll within the overlay. Effective height is still clamped to your active monitor's work area."/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OverlayMaxHeight, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="200" Maximum="4320" Value="{Binding OverlayMaxHeight}"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    ToolTip="Maximum height the overlay can grow to before scrolling"/>
                        </DockPanel>

                        <TextBlock Text="Height Presets" Style="{StaticResource SettingLabel}" ToolTip="Quickly set max-height targets for common display classes."/>
                        <UniformGrid Columns="4" Margin="0,4,0,8">
                            <Button Content="1080p" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="1080p"/>
                            <Button Content="2K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="2k"/>
                            <Button Content="4K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="4k"/>
                            <Button Content="8K" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="8k"/>
                        </UniformGrid>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AllowManualResize}"
                                          ToolTip="Allow drag-resizing from left/right edges of the overlay"/>
                            <TextBlock Text="Allow Manual Resize" Style="{StaticResource SettingLabel}" ToolTip="When enabled, drag the left or right edge of the overlay to resize quickly"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SNAPPING" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SnapToEdges}"
                                          ToolTip="Overlay snaps to screen edges when dragged nearby"/>
                            <TextBlock Text="Snap to Screen Edges" Style="{StaticResource SettingLabel}" ToolTip="The overlay automatically aligns to screen edges when dragged close to them"/>
                        </DockPanel>

                        <TextBlock Text="Snap Distance" Style="{StaticResource SettingLabel}" ToolTip="How close (in pixels) the overlay needs to be before it snaps into place"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding SnapDistance, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="5" Maximum="50" Value="{Binding SnapDistance}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ToolTip="How close to a screen edge before the overlay snaps"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="STARTUP" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding StartWithWindows}"
                                          ToolTip="Automatically start Notifications Pro when you sign in to Windows"/>
                            <TextBlock Text="Start with Windows" Style="{StaticResource SettingLabel}" ToolTip="Automatically launch Notifications Pro when you sign in"/>
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ═══ SOUNDS TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Sounds settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- volume-2 -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z M16 9a5 5 0 0 1 0 6 M19.364 18.364a9 9 0 0 0 0-12.728" />
                        <TextBlock Text="Sounds"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="NOTIFICATION SOUNDS" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SoundEnabled}"
                                          ToolTip="Play a sound when a notification arrives"/>
                            <TextBlock Text="Notification Sounds" Style="{StaticResource SettingLabel}"
                                       ToolTip="Play a sound when a new notification is captured and displayed"/>
                        </DockPanel>

                        <TextBlock Text="Default Sound" Style="{StaticResource SettingLabel}"
                                   ToolTip="Windows sound played for all notifications unless overridden per app. To assign different sounds per app, see the Filtering tab → Per-App Sounds &amp; Icons."/>
                        <DockPanel Margin="0,4,0,8">
                            <Button DockPanel.Dock="Right" Content="Test" Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" Command="{Binding TestSoundCommand}"
                                    ToolTip="Play the currently selected sound now"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                      ItemsSource="{Binding AvailableWindowsSounds}"
                                      SelectedItem="{Binding SelectedWindowsSound}"
                                      ToolTip="Windows sound to play for all notifications (unless overridden per app)">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource UIFont}" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>

                        <Button Content="Browse Custom Sound..." Style="{StaticResource SecondaryButton}"
                                Margin="0,0,0,4" HorizontalAlignment="Left"
                                Command="{Binding BrowseCustomSoundCommand}"
                                ToolTip="Import a WAV file as a custom notification sound"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ STREAMING TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Streaming settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- video -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5 M4 6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H4z" />
                        <TextBlock Text="Streaming"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="QUICK SETUP" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <Button Content="Apply OBS Streaming Preset" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApplyStreamingPresetCommand}" HorizontalAlignment="Left"
                                Padding="16,8" Margin="0,0,0,16"
                                ToolTip="Enables Chroma Key (green), Fixed Window Mode, and Per-App Tinting in one click"/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="CHROMA KEY" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ChromaKeyEnabled}"
                                          ToolTip="Replace the transparent overlay background with a solid chroma key color for OBS/streaming capture"/>
                            <TextBlock Text="Enable Chroma Key Background" Style="{StaticResource SettingLabel}" ToolTip="Replaces the transparent background with a solid color for chroma key capture in OBS or other streaming tools"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding ChromaKeyEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Chroma Key Color" Style="{StaticResource SettingLabel}"/>
                            <WrapPanel Margin="0,4,0,0">
                                <Button Content="Green" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                        Tag="ChromaKeyColor" Click="OnPickChromaPreset" CommandParameter="#00FF00"
                                        ToolTip="Standard green screen (#00FF00)"/>
                                <Button Content="Blue" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                        Tag="ChromaKeyColor" Click="OnPickChromaPreset" CommandParameter="#0000FF"
                                        ToolTip="Blue screen (#0000FF)"/>
                                <Button Content="Magenta" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                        Tag="ChromaKeyColor" Click="OnPickChromaPreset" CommandParameter="#FF00FF"
                                        ToolTip="Magenta screen (#FF00FF)"/>
                                <Button Content="Pick..." Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                        Tag="ChromaKeyColor" Click="OnPickColorClick"
                                        ToolTip="Choose a custom chroma key color"/>
                            </WrapPanel>
                            <DockPanel Margin="0,0,0,8">
                                <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                                        Background="{Binding ChromaKeyColor, Converter={StaticResource ColorToBrush}}"/>
                                <TextBlock Text="{Binding ChromaKeyColor}" Style="{StaticResource SettingLabel}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           VerticalAlignment="Center"
                                           ToolTip="Use the same color in your OBS Chroma Key filter to make the background transparent"/>
                            </DockPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="OBS WINDOW CAPTURE" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ObsFixedWindowMode}"
                                          ToolTip="Set the overlay to a fixed size for consistent OBS window capture"/>
                            <TextBlock Text="Fixed Window Size" Style="{StaticResource SettingLabel}" ToolTip="Locks the overlay to a fixed width and height for consistent capture in OBS window capture mode. Tip: Enable Chroma Key above, then use OBS Window Capture on the overlay with a Chroma Key filter."/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding ObsFixedWindowMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Fixed Width" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding ObsFixedWidth, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="200" Maximum="1920" Value="{Binding ObsFixedWidth}"
                                        TickFrequency="10" IsSnapToTickEnabled="True"
                                        ToolTip="Fixed overlay width for OBS capture"/>
                            </DockPanel>

                            <TextBlock Text="Fixed Height" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding ObsFixedHeight, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="200" Maximum="1080" Value="{Binding ObsFixedHeight}"
                                        TickFrequency="10" IsSnapToTickEnabled="True"
                                        ToolTip="Fixed overlay height for OBS capture"/>
                            </DockPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="PRESENTATION MODE" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding PresentationModeEnabled}"
                                          ToolTip="Auto-pause notifications when a presentation app goes fullscreen"/>
                            <TextBlock Text="Auto-DND on Fullscreen" Style="{StaticResource SettingLabel}" ToolTip="Automatically pauses notifications when a configured app is running fullscreen (PowerPoint, Zoom, etc.)"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding PresentationModeEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Monitored Apps" Style="{StaticResource SettingLabel}" ToolTip="Notifications pause when any of these apps go fullscreen"/>

                            <ItemsControl ItemsSource="{Binding PresentationApps}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Content="Remove" Style="{StaticResource SecondaryButton}"
                                                    Width="72" Padding="0"
                                                    Command="{Binding DataContext.RemovePresentationAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" Margin="8,0,0,0"
                                                    ToolTip="Remove this app from presentation-mode monitoring"/>
                                            <TextBlock Text="{Binding}" Style="{StaticResource SettingLabel}" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Content="Add App" Style="{StaticResource SecondaryButton}"
                                        MinWidth="110" Command="{Binding AddPresentationAppCommand}" Margin="8,0,0,0"
                                        ToolTip="Add this process name to presentation-mode monitoring"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding NewPresentationApp, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Process name to monitor (e.g. PowerPoint, Zoom)"/>
                            </DockPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="PER-APP COLOR TINTING" Style="{StaticResource SectionHeader}"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding PerAppTintEnabled}"
                                          ToolTip="Apply a subtle color tint to notification cards based on the source app"/>
                            <TextBlock Text="Enable Per-App Color Tint" Style="{StaticResource SettingLabel}" ToolTip="Adds a subtle color tint to each notification card based on the source app name (Teams = blue, Slack = purple, etc.)"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding PerAppTintEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Tint Intensity" Style="{StaticResource SettingLabel}" ToolTip="Higher values make the per-app color more visible; lower values are more subtle"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding PerAppTintOpacity, StringFormat='{}{0:P0}'}"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="0.05" Maximum="0.40" Value="{Binding PerAppTintOpacity}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        ToolTip="How strongly the app color tints the card background"/>
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ═══ ACCESSIBILITY TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Accessibility settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- accessibility -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M16 4a1 1 0 1 0-2 0 1 1 0 0 0 2 0z m2 15 1-7-6 1 m-8-5 3-3 5.5 3-2.36 3.5 M4.24 14.5a5 5 0 0 0 6.88 6 M13.76 17.5a5 5 0 0 0-6.88-6" />
                        <TextBlock Text="Accessibility"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="ACCESSIBILITY" Style="{StaticResource SectionHeader}"
                                       ToolTip="Accessibility features for reading and managing notifications. Capture uses WinRT (preferred) or Accessibility fallback automatically. Check the tray icon tooltip for current mode."/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AccessibilityModeEnabled}"
                                          ToolTip="Enable recommended accessibility settings as a bundle"/>
                            <TextBlock Text="Accessibility Mode" Style="{StaticResource SettingLabel}"
                                       ToolTip="Enables persistent notifications, respect for system motion/contrast/text settings, and spacious layout in one click. Individual settings below still work independently."/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="NOTIFICATION TIMING" Style="{StaticResource SectionHeader}"
                                       ToolTip="Control how long notifications stay visible on screen."/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding PersistentNotifications}"
                                          ToolTip="Notifications stay on screen until manually dismissed"/>
                            <TextBlock Text="Persistent Notifications" Style="{StaticResource SettingLabel}" ToolTip="Notifications remain visible until you click to dismiss them (no auto-expiry)"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AutoDurationEnabled}"
                                          ToolTip="Automatically extend display time for longer notifications"/>
                            <TextBlock Text="Auto-Duration (Longer Text = More Time)" Style="{StaticResource SettingLabel}" ToolTip="Calculates display time based on notification length so you have time to read"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding AutoDurationEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Base Duration" Style="{StaticResource SettingLabel}" ToolTip="Starting duration before adding time per line of text"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding AutoDurationBaseSeconds, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="2" Maximum="30" Value="{Binding AutoDurationBaseSeconds}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ToolTip="Minimum display time before per-line additions"/>
                            </DockPanel>

                            <TextBlock Text="Seconds Per Line" Style="{StaticResource SettingLabel}" ToolTip="Additional seconds added for each line of notification body text"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding AutoDurationSecondsPerLine, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="0.5" Maximum="5" Value="{Binding AutoDurationSecondsPerLine}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ToolTip="Extra display time added per estimated line of text"/>
                            </DockPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SYSTEM INTEGRATION" Style="{StaticResource SectionHeader}"
                                       ToolTip="Automatically adapt the overlay to match your Windows accessibility settings."/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding RespectReduceMotion}"
                                          ToolTip="Disable slide animations when Windows 'Reduce Motion' is active"/>
                            <TextBlock Text="Respect Reduce Motion" Style="{StaticResource SettingLabel}" ToolTip="Automatically switches to fade-only transitions when Windows animation settings are off"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding RespectHighContrast}"
                                          ToolTip="Auto-apply High Contrast theme when Windows HC mode is active"/>
                            <TextBlock Text="Respect High Contrast" Style="{StaticResource SettingLabel}" ToolTip="Automatically switches to the High Contrast built-in theme when Windows HC mode activates"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding RespectTextScaling}"
                                          ToolTip="Scale overlay font sizes according to Windows text scaling setting"/>
                            <TextBlock Text="Respect Text Scaling" Style="{StaticResource SettingLabel}" ToolTip="Scales notification text to match your Windows accessibility text size setting"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="GLOBAL HOTKEYS" Style="{StaticResource SectionHeader}"
                                       ToolTip="Control the overlay from anywhere using system-wide keyboard shortcuts."/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding GlobalHotkeysEnabled}"
                                          ToolTip="Register system-wide keyboard shortcuts"/>
                            <TextBlock Text="Enable Global Hotkeys" Style="{StaticResource SettingLabel}" ToolTip="Register system-wide keyboard shortcuts to control the overlay without the mouse"/>
                        </DockPanel>

                        <StackPanel Margin="12,0,0,0" Visibility="{Binding GlobalHotkeysEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Toggle Overlay" Style="{StaticResource SettingLabel}" ToolTip="Show or hide the notification overlay"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding HotkeyToggleOverlay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Keyboard combo to show/hide the overlay (e.g. Ctrl+Alt+N)"/>

                            <TextBlock Text="Dismiss All" Style="{StaticResource SettingLabel}" ToolTip="Clear all visible notifications at once"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding HotkeyDismissAll, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Keyboard combo to clear all visible notifications (e.g. Ctrl+Alt+D)"/>

                            <TextBlock Text="Toggle Do Not Disturb" Style="{StaticResource SettingLabel}" ToolTip="Pause or resume notification delivery"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding HotkeyToggleDnd, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Keyboard combo to pause/resume notifications (e.g. Ctrl+Alt+P)"/>
                        </StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="INFORMATION DENSITY" Style="{StaticResource SectionHeader}"
                                       ToolTip="Choose how much information fits on screen at once. Compact shows more notifications, Spacious is easier to read."/>
                        </Border>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Compact" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ApplyDensityPresetCommand}" CommandParameter="Compact"
                                    ToolTip="Smaller text, tighter spacing — fits more notifications on screen"/>
                            <Button Content="Comfortable" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ApplyDensityPresetCommand}" CommandParameter="Comfortable"
                                    ToolTip="Default balanced layout with readable sizing"/>
                            <Button Content="Spacious" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ApplyDensityPresetCommand}" CommandParameter="Spacious"
                                    ToolTip="Larger text, generous spacing — easier to read at a distance"/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ═══ UI STYLING TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="UI Styling settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- brush -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="m11 10 3 3 M6.5 21A3.5 3.5 0 1 0 3 17.5a2.62 2.62 0 0 1-.708 1.792A1 1 0 0 0 3 21z M9.969 17.031 21.378 5.624a1 1 0 0 0-3.002-3.002L6.967 14.031" />
                        <TextBlock Text="UI Styling"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="DISPLAY MODE" Style="{StaticResource SectionHeader}"
                                       ToolTip="Customize the appearance and behavior of this settings window. These options do not affect the notification overlay."/>
                        </Border>

                        <TextBlock Text="Display Mode" Style="{StaticResource SettingLabel}"
                                   ToolTip="Window: standard resizable settings window. Popup (default): borderless panel anchored to the Windows toast corner on the taskbar monitor."/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableSettingsDisplayModes}"
                                  SelectedItem="{Binding SettingsDisplayMode}"
                                  Margin="0,4,0,0"
                                  ToolTip="Window mode opens a normal resizable window. Popup mode anchors to the same corner where Windows toasts appear."
                                  />

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding PopupAutoClose}"
                                          ToolTip="Automatically close the popup when you click elsewhere"/>
                            <TextBlock Text="Auto-Close Popup on Deactivate" Style="{StaticResource SettingLabel}" ToolTip="In Popup mode, automatically closes the settings panel when it loses focus"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="WINDOW SHAPE" Style="{StaticResource SectionHeader}"
                                       ToolTip="Control the visual shape of the settings window. Corner rounding applies in Popup mode; Window mode uses system-level rounding."/>
                        </Border>

                        <TextBlock Text="Corner Radius" Style="{StaticResource SettingLabel}"
                                   ToolTip="Adjusts the roundness of the settings window corners (0 = sharp, 20 = very round). In Popup mode this uses XAML clipping; in Window mode it uses the Windows 11 DWM API."/>
                        <DockPanel Margin="0,4,0,8">
                            <TextBlock DockPanel.Dock="Right" Width="30" TextAlignment="Right"
                                       Text="{Binding SettingsWindowCornerRadius, StringFormat={}{0:0}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding SettingsWindowCornerRadius}"
                                    Style="{StaticResource SettingsSlider}"
                                    ToolTip="Drag to adjust corner rounding (0–20 px)"/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="THEME" Style="{StaticResource SectionHeader}"
                                       ToolTip="Choose a preset theme for the settings window or create your own custom palette below."/>
                        </Border>

                        <TextBlock Text="UI Theme Preset" Style="{StaticResource SettingLabel}"
                                   ToolTip="Use the same named themes as the overlay for a consistent look. System follows Windows. Custom uses the color fields below."/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableSettingsThemeModes}"
                                  SelectedItem="{Binding SettingsThemeMode}"
                                  Margin="0,4,0,0"
                                  ToolTip="Uses the same named theme presets as the overlay (plus System and Custom)."/>

                        <DockPanel Margin="0,0,0,8">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding LinkOverlayThemeAndUiTheme}"
                                          ToolTip="When enabled, applying an overlay theme also updates the Settings UI palette"/>
                            <TextBlock Text="Link Overlay Theme to UI Theme" Style="{StaticResource SettingLabel}"
                                       ToolTip="Off (recommended): overlay themes and Settings UI theme are independent. On: applying a theme updates both."/>
                        </DockPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="CUSTOM COLORS" Style="{StaticResource SectionHeader}"
                                       ToolTip="Fine-tune settings-window colors. These apply when UI Theme Preset is set to Custom."/>
                        </Border>

                        <TextBlock Text="Background" Style="{StaticResource SettingLabel}" ToolTip="Main background color of the settings window"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowBg, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowBg" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowBg, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Surface" Style="{StaticResource SettingLabel}" ToolTip="Color for panels, cards, and elevated surfaces"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowSurface, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowSurface" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowSurface, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Surface Light" Style="{StaticResource SettingLabel}" ToolTip="Lighter surface variant used for input fields and secondary panels"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowSurfaceLight, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowSurfaceLight" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowSurfaceLight, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Surface Hover" Style="{StaticResource SettingLabel}" ToolTip="Color shown when hovering over interactive elements"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowSurfaceHover, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowSurfaceHover" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowSurfaceHover, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Text" Style="{StaticResource SettingLabel}" ToolTip="Primary text color for labels and headings"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowText, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowText" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowText, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Text Secondary" Style="{StaticResource SettingLabel}" ToolTip="Secondary text color for descriptions and help text"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowTextSecondary, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowTextSecondary" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowTextSecondary, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Text Muted" Style="{StaticResource SettingLabel}" ToolTip="Muted text color for placeholders and disabled labels"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowTextMuted, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowTextMuted" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowTextMuted, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Accent" Style="{StaticResource SettingLabel}" ToolTip="Accent color for active toggles, selected tabs, and highlights"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowAccent, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowAccent" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowAccent, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Text="Border" Style="{StaticResource SettingLabel}" ToolTip="Border color for separators, input outlines, and dividers"/>
                        <DockPanel Margin="0,4,0,4">
                            <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding SettingsWindowBorder, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick" Style="{StaticResource ColorPickButton}"
                                    Margin="8,0,0,0"
                                    Tag="SettingsWindowBorder" Click="OnPickColorClick"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Text="{Binding SettingsWindowBorder, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ PROFILES TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Profiles settings tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- users -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M16 3.128a4 4 0 0 1 0 7.744 M22 21v-2a4 4 0 0 0-3-3.87 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" />
                        <TextBlock Text="Profiles"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SAVED PROFILES" Style="{StaticResource SectionHeader}"
                                       ToolTip="Save and switch between named configuration profiles (e.g., Work, Gaming, Streaming). Each profile stores all settings."/>
                        </Border>

                        <DockPanel Margin="0,4,0,8">
                            <Button DockPanel.Dock="Right" Content="Save" Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0" Command="{Binding SaveProfileCommand}"
                                    ToolTip="Save current settings as a new profile"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter a name for the profile (e.g., Work, Gaming, Streaming)"/>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding SavedProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="Delete" Style="{StaticResource SecondaryButton}"
                                                Padding="8,4" Margin="8,0,0,0"
                                                Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Delete this profile"/>
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Padding="10,6" HorizontalContentAlignment="Left"
                                                Command="{Binding DataContext.LoadProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Load this profile (replaces all current settings)">
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="IMPORT / EXPORT" Style="{StaticResource SectionHeader}"
                                       ToolTip="Save and restore complete app settings (all tabs) as JSON files."/>
                        </Border>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Export Settings" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,8" Command="{Binding ExportSettingsCommand}"
                                    ToolTip="Save all current settings to a JSON file"/>
                            <Button Content="Import Settings" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,8" Command="{Binding ImportSettingsCommand}"
                                    ToolTip="Load settings from a previously exported JSON file. Import replaces all settings, including behavior, appearance, position, and filtering."/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ HELP TAB ═══ -->
            <TabItem Style="{StaticResource SettingsTabItem}" AutomationProperties.Name="Help tab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <!-- circle-help -->
                        <Path Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5" Fill="Transparent" 
                              Data="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3 M12 17h.01" />
                        <TextBlock Text="Help"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                                   Text="Notifications Pro mirrors Windows toast notifications into a fully customisable always-on-top overlay — so you can read every notification, in full, without clicking anything."/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="USING TOOLTIPS" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="Most settings in this window have a built-in tooltip that explains what the setting does and how to use it. To view a tooltip, hover your mouse over any setting label or section header and hold it there for a moment."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   Text="Tip: If you are unsure what a setting does, hover over its label — the tooltip will appear within a second."/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="GRANTING NOTIFICATION ACCESS" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="On first run, Notifications Pro requests notification access from Windows. If it was denied or not granted:"/>
                        <TextBlock TextWrapping="Wrap" Margin="12,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="1. Open Windows Settings → System → Notifications (search 'notification access' if needed)."/>
                        <TextBlock TextWrapping="Wrap" Margin="12,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="2. Find the Notification Access section and enable access for Notifications Pro."/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,12"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   Text="The tray menu also has 'Grant Notification Access' and 'Retry Access Check' for troubleshooting. Even without WinRT access, an accessibility fallback captures notifications automatically."/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="OVERLAY INTERACTION" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Left-click a card" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Dismiss it"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Right-click a card" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Context menu: dismiss, copy text, clear all, mute app"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Drag anywhere" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Reposition the overlay on any monitor"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Hover" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Pauses all expiry timers so you can finish reading"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Drag left/right edge" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Resize width (when manual resize is enabled)"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                        </Grid>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="WHY CAN'T I CLICK NOTIFICATIONS TO OPEN APPS?" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="This is intentional for three reasons:"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                            <Run FontWeight="SemiBold" Text="• Safety — "/>
                            <Run Text="an always-on-top overlay with clickable URLs increases the risk of accidental clicks and phishing. URLs render as plain text only."/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                            <Run FontWeight="SemiBold" Text="• Predictability — "/>
                            <Run Text="Windows toasts include action buttons and rich media. The overlay is intentionally passive (read / dismiss / copy) so behaviour is consistent across both the WinRT and accessibility capture paths."/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,8"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                            <Run FontWeight="SemiBold" Text="• Privacy — "/>
                            <Run Text="rendering images from notification payloads would require decoding potentially remote content."/>
                        </TextBlock>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="TROUBLESHOOTING" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="No notifications captured" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Verify permission, then use tray 'Retry Access Check'. The app falls back to accessibility capture automatically."/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Can't drag the overlay" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Click-through is on. Disable from tray menu or Settings → Behavior."/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Windows toasts stop appearing" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Ensure 'Suppress Toast Popups' is off in Settings → Behavior."/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Overlay disappears off-screen" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Use Settings → Layout → Quick Position presets to move it back."/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Sounds all sound the same" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Windows 11 unified many system sound events. Use a custom WAV file from Settings → Sounds → Browse for distinct audio."/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Hotkeys don't work" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Check the hotkey format (e.g. Ctrl+Alt+N) and ensure 'Enable Global Hotkeys' is on in Settings → Accessibility."/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Overlay too large on screen" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       Text="Use Settings → Size to reduce width or max height. Height presets match common display resolutions."/>
                        </Grid>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+T (in settings)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Send a test notification"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Global hotkeys" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Configure in Settings → Accessibility: toggle overlay, dismiss all, toggle DND"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Hotkey format" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Use modifier+key combos like Ctrl+Alt+N or Shift+F12. Hotkeys require the Accessibility tab toggle enabled."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Tray right-click" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Show/hide overlay, DND, always-on-top, click-through, focus mode, clear all, switch profile"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+Z / Ctrl+Y" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Undo / redo settings changes"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Escape" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Close settings window"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="CLI arguments" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="--pause, --resume, --theme &lt;name&gt;, --send-test, --hide, --show"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        </Grid>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SETTINGS OVERVIEW" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Appearance" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Overlay themes, theme scheduling, font presets (OpenDyslexic), typography, colors, shapes, icons, scrollbar, and fullscreen mode"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Behavior" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Timing, content visibility, single-line mode, group-by-app, animations, deduplication, and toast suppression"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Filtering" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Per-app muting, keyword highlighting and muting, per-app sounds/icons, quiet hours, and burst limiting"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Layout" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Monitor selection, quick-position presets, overlay width/height, resize, snapping, and startup"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Sounds" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Default notification sound selection and custom WAV import"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Streaming" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Chroma key, OBS fixed window capture, presentation mode, and per-app color tinting"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Accessibility" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Persistent notifications, auto-duration, system integration, hotkeys, and density presets"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="UI Styling" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="Settings window display mode, corner radius, theme, and custom color palette"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Profiles" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="Save and load named configuration profiles, import/export settings as JSON"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        </Grid>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="PRIVACY" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="Notifications Pro is designed to avoid persisting notification content:"/>
                        <TextBlock TextWrapping="Wrap" Margin="12,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="• No notification title or body is ever written to disk — no database, no cache, no logs."/>
                        <TextBlock TextWrapping="Wrap" Margin="12,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="• Notification content exists only in RAM while displayed, and is released immediately after dismissal or expiry."/>
                        <TextBlock TextWrapping="Wrap" Margin="12,0,0,12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="• The app makes no network calls and includes no telemetry."/>

                        <Border Style="{StaticResource SectionHeaderPanel}">
                            <TextBlock Text="SUPPORT &amp; UPDATES" Style="{StaticResource SectionHeader}"/>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="This project is open source and actively maintained on GitHub."/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Text="Repository: "/>
                            <TextBlock Cursor="Hand" TextDecorations="Underline" FontSize="12"
                                       Foreground="{DynamicResource AccentBrush}">
                                <Hyperlink NavigateUri="https://github.com/lwytch/Notifications-Pro">
                                    github.com/lwytch/Notifications-Pro
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   Text="Check the repository for new updates, to report bugs, or to request new features!"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Footer with preview button -->
        <Border Grid.Row="4" Padding="24,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Reset to Defaults" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetToDefaultsCommand}" Margin="0,0,8,0"
                            ToolTip="Restore all settings to their original values"/>
                    <Button Content="Send Test Notification" Style="{StaticResource PrimaryButton}"
                            Command="{Binding PreviewNotificationCommand}"
                            ToolTip="Shows a sample notification in the overlay (Ctrl+T)"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Changes are saved automatically"
                               FontFamily="{StaticResource UIFont}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock x:Name="SavedIndicator" Text=" Saved"
                               FontFamily="{StaticResource UIFont}" FontSize="11"
                               Foreground="{DynamicResource AccentBrush}"
                               Visibility="{Binding ShowSavedIndicator, Converter={StaticResource BoolToVis}}"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
    </Border>
</Window>
