<Window x:Class="NotificationsPro.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:NotificationsPro.Converters"
        Title="Notifications Pro — Settings"
        Icon="{Binding TrayIconImage}"
        Width="560" Height="640" MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <converters:BoolToMuteLabelConverter x:Key="BoolToMuteLabel"/>
        <converters:ZeroToVisibleConverter x:Key="ZeroToVisible"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,20,0,12"/>
        </Style>

        <!-- Setting label -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Setting description -->
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,16"/>
        </Style>

        <!-- Value display next to slider -->
        <Style x:Key="SliderValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="ColorPickButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Border Width="36" Height="36" CornerRadius="10"
                        Background="{StaticResource SurfaceLightBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,12,0">
                    <Image Source="{Binding TrayIconImage}" Width="22" Height="22"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="Settings" FontFamily="{StaticResource UIFont}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Customize how notifications appear on your screen"
                               FontFamily="{StaticResource UIFont}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Style="{StaticResource SettingsTabControl}" Margin="24,0">

            <!-- ═══ THEMES TAB ═══ -->
            <TabItem Header="Themes" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <TextBlock Text="BUILT-IN THEMES" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="One-click apply sets colors, opacity, shape, and accent at once"
                                   Style="{StaticResource SettingDesc}"/>

                        <ItemsControl ItemsSource="{Binding BuiltInThemes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,8" MinWidth="100" Padding="12,8"
                                            Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="14" Height="14" CornerRadius="3"
                                                    Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="CUSTOM THEMES" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Save your current look as a named theme"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,4,0,8">
                            <Button DockPanel.Dock="Right" Content="Save" Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0" Command="{Binding SaveCustomThemeCommand}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewThemeName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter a name for the custom theme"/>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding CustomThemes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="X" Style="{StaticResource SecondaryButton}"
                                                MinWidth="28" Padding="6,2" Margin="4,0,0,0"
                                                Command="{Binding DataContext.DeleteCustomThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Name}"
                                                ToolTip="Delete this custom theme"/>
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Padding="10,6" HorizontalContentAlignment="Left"
                                                Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Apply this custom theme">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="14" Height="14" CornerRadius="3"
                                                        Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                                                        Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No custom themes saved yet"
                                   Style="{StaticResource SettingDesc}" Margin="0,4,0,0"
                                   Visibility="{Binding CustomThemes.Count, Converter={StaticResource ZeroToVisible}}"/>

                        <TextBlock Text="IMPORT / EXPORT" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Share your full settings (all tabs) as a JSON file"
                                   Style="{StaticResource SettingDesc}"/>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Export Settings" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,8" Command="{Binding ExportSettingsCommand}"
                                    ToolTip="Save all current settings to a JSON file"/>
                            <Button Content="Import Settings" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,8" Command="{Binding ImportSettingsCommand}"
                                    ToolTip="Load settings from a previously exported JSON file"/>
                        </WrapPanel>
                        <TextBlock Text="Import replaces all settings including behavior, position, and filtering"
                                   Style="{StaticResource SettingDesc}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ APPEARANCE TAB ═══ -->
            <TabItem Header="Appearance" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <!-- TYPOGRAPHY section -->
                        <TextBlock Text="TYPOGRAPHY" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Font Family" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding FontFamily}"
                                  ToolTip="The typeface used for notification text"
                                  Margin="0,4,0,0"/>
                        <TextBlock Text="Typeface used for all notification text in the overlay"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Body Font Size" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding FontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="56" Value="{Binding FontSize}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Controls body text size"/>
                        </DockPanel>
                        <TextBlock Text="Size of the notification body text"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Body Font Weight" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFontWeights}"
                                  SelectedItem="{Binding FontWeight}"
                                  ToolTip="How bold or light the notification body text appears"
                                  Margin="0,4,0,0"/>
                        <TextBlock Text="Thickness of the notification body text"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="App Name Font Size" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding AppNameFontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="56" Value="{Binding AppNameFontSize}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Controls the size of app name text"/>
                        </DockPanel>
                        <TextBlock Text="Size of the source app name line (Teams, Slack, etc.)"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="App Name Font Weight" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFontWeights}"
                                  SelectedItem="{Binding AppNameFontWeight}"
                                  ToolTip="How bold the app name text appears"
                                  Margin="0,4,0,0"/>
                        <TextBlock Text="Thickness of the source app name text"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Title Font Size" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding TitleFontSize, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="56" Value="{Binding TitleFontSize}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Controls the size of notification title text"/>
                        </DockPanel>
                        <TextBlock Text="Size of the notification title line"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Title Font Weight" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableFontWeights}"
                                  SelectedItem="{Binding TitleFontWeight}"
                                  ToolTip="How bold the title text appears"
                                  Margin="0,4,0,0"/>
                        <TextBlock Text="Thickness of the notification title text"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Line Spacing" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}"
                                       Text="{Binding LineSpacing, StringFormat='{}{0:0.0}'}"/>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1.0" Maximum="2.5" Value="{Binding LineSpacing}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    ToolTip="Space between lines of text — increase for readability"/>
                        </DockPanel>
                        <TextBlock Text="More spacing makes dense notifications easier to scan"
                                   Style="{StaticResource SettingDesc}"/>

                        <!-- COLORS section -->
                        <TextBlock Text="COLORS" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Title Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding TitleColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="TitleColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for notification title text"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding TitleColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for notification titles (e.g. #FFFFFF)"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Color of the notification title text" Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="App Name Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding AppNameColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="AppNameColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for app-name text"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding AppNameColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for source app names (e.g. #B8B8CC)"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Color used for the source app line (Teams, Slack, Outlook, etc.)"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Body Text Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding TextColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="TextColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for notification body text"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for notification body text (e.g. #E4E4EF)"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Color of the notification body content" Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Background Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="BackgroundColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for card background"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for the notification card background"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Background of each notification card" Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Accent Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="AccentColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for accent stripe"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for the left accent stripe on notification cards"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Colored stripe on the left edge of each notification card"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Background Opacity" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}"
                                       Text="{Binding BackgroundOpacity, StringFormat='{}{0:P0}'}"/>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0.1" Maximum="1.0" Value="{Binding BackgroundOpacity}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    ToolTip="How transparent the notification background appears"/>
                        </DockPanel>
                        <TextBlock Text="Lower values make cards more transparent so you can see through them"
                                   Style="{StaticResource SettingDesc}"/>

                        <!-- SHAPE section -->
                        <TextBlock Text="SHAPE" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Corner Radius" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding CornerRadius, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="24" Value="{Binding CornerRadius}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Roundness of notification card corners"/>
                        </DockPanel>
                        <TextBlock Text="0 for sharp corners, higher values for rounder cards"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Padding" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding Padding, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="4" Maximum="32" Value="{Binding Padding}"
                                    TickFrequency="2" IsSnapToTickEnabled="True"
                                    ToolTip="Internal spacing between card edge and text"/>
                        </DockPanel>
                        <TextBlock Text="Space between the card edge and the notification text"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Card Gap" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding CardGap, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="24" Value="{Binding CardGap}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Vertical spacing between notification cards"/>
                        </DockPanel>
                        <TextBlock Text="Vertical space between each notification card"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Outer Margin" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OuterMargin, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="24" Value="{Binding OuterMargin}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Margin around the card area within the overlay"/>
                        </DockPanel>
                        <TextBlock Text="Space around the entire card area inside the overlay window"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="ACCENT STRIPE" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowAccent}"
                                          ToolTip="Show or hide the colored accent stripe on the left edge of cards"/>
                            <TextBlock Text="Show Accent Stripe" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Colored bar on the left edge of each notification card"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Accent Thickness" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding AccentThickness, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1" Maximum="8" Value="{Binding AccentThickness}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Width of the accent stripe on each card"/>
                        </DockPanel>
                        <TextBlock Text="Width of the left accent stripe in pixels"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="CARD BORDER" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowBorder}"
                                          ToolTip="Show or hide a border around each notification card"/>
                            <TextBlock Text="Show Card Border" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Adds a subtle border around each notification card"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Border Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding BorderColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="BorderColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for card border"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding BorderColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for the card border (e.g. #363650)"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Color of the border around notification cards"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Border Thickness" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding BorderThickness, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1" Maximum="4" Value="{Binding BorderThickness}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Thickness of the card border"/>
                        </DockPanel>
                        <TextBlock Text="Width of the border around each card in pixels"
                                   Style="{StaticResource SettingDesc}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ BEHAVIOR TAB ═══ -->
            <TabItem Header="Behavior" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <TextBlock Text="TIMING" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Notification Duration" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding NotificationDuration, StringFormat='{}{0:0}'}"/><Run Text="s"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="2" Maximum="120" Value="{Binding NotificationDuration}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="How long each notification stays visible before fading out"/>
                        </DockPanel>
                        <TextBlock Text="Seconds each notification remains on screen before auto-dismissing"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Visible Notifications" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding MaxVisibleNotifications, StringFormat='{}{0:0}'}"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="1" Maximum="40" Value="{Binding MaxVisibleNotifications}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="Maximum number of notification cards shown at once"/>
                        </DockPanel>
                        <TextBlock Text="Lower counts reduce visual noise; higher counts keep more context visible"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="CONTENT" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowAppName}"
                                          ToolTip="Display the source app name on each card"/>
                            <TextBlock Text="Show App Name" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Useful when multiple apps notify at once and you need source context quickly"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowNotificationTitle}"
                                          ToolTip="Display the notification title line"/>
                            <TextBlock Text="Show Title" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Primary headline line from each notification"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowNotificationBody}"
                                          ToolTip="Display the notification body content"/>
                            <TextBlock Text="Show Body Text" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Long-form notification content; automatically kept on if all fields are turned off"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ShowTimestamp}"
                                          ToolTip="Show a relative timestamp on each notification card"/>
                            <TextBlock Text="Show Timestamp" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Displays how long ago each notification arrived (e.g. '2m ago')"
                                   Style="{StaticResource SettingDesc}"/>

                        <StackPanel Visibility="{Binding IsStackedLayout, Converter={StaticResource BoolToVis}}">
                            <DockPanel Margin="0,0,0,4">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NewestOnTop}"
                                              ToolTip="When on, newest notifications appear first at the top. Turn off for chronological top-to-bottom flow."/>
                                <TextBlock Text="Newest on Top" Style="{StaticResource SettingLabel}"/>
                            </DockPanel>
                            <TextBlock Text="Turn off to let new notifications appear underneath older ones."
                                       Style="{StaticResource SettingDesc}"/>

                            <DockPanel Margin="0,0,0,4">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding LimitTextLines}"
                                              ToolTip="Limit text height and truncate long notifications with ellipsis"/>
                                <TextBlock Text="Limit Text Lines (Truncate)" Style="{StaticResource SettingLabel}"/>
                            </DockPanel>
                            <TextBlock Text="Turn this off for full multi-line word wrap with no truncation in stacked mode"
                                       Style="{StaticResource SettingDesc}"/>

                            <StackPanel Visibility="{Binding LimitTextLines, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="App Name Max Lines" Style="{StaticResource SettingLabel}"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                        <Run Text="{Binding MaxAppNameLines, StringFormat='{}{0:0}'}"/>
                                    </TextBlock>
                                    <Slider Style="{StaticResource SettingsSlider}"
                                            Minimum="1" Maximum="4" Value="{Binding MaxAppNameLines}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ToolTip="Maximum displayed lines for app-name text in stacked mode"/>
                                </DockPanel>
                                <TextBlock Text="Limit source app text height before truncation in stacked mode"
                                           Style="{StaticResource SettingDesc}"/>

                                <TextBlock Text="Title Max Lines" Style="{StaticResource SettingLabel}"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                        <Run Text="{Binding MaxTitleLines, StringFormat='{}{0:0}'}"/>
                                    </TextBlock>
                                    <Slider Style="{StaticResource SettingsSlider}"
                                            Minimum="1" Maximum="6" Value="{Binding MaxTitleLines}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ToolTip="Maximum displayed lines for notification titles in stacked mode"/>
                                </DockPanel>
                                <TextBlock Text="Keeps title cards compact while still showing key context"
                                           Style="{StaticResource SettingDesc}"/>

                                <TextBlock Text="Body Max Lines" Style="{StaticResource SettingLabel}"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                        <Run Text="{Binding MaxBodyLines, StringFormat='{}{0:0}'}"/>
                                    </TextBlock>
                                    <Slider Style="{StaticResource SettingsSlider}"
                                            Minimum="1" Maximum="10" Value="{Binding MaxBodyLines}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ToolTip="Maximum displayed lines for notification body text in stacked mode"/>
                                </DockPanel>
                                <TextBlock Text="Controls how much message text is shown before truncating with ellipsis"
                                           Style="{StaticResource SettingDesc}"/>
                            </StackPanel>
                        </StackPanel>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SingleLineMode}"
                                          ToolTip="Render each notification as a single horizontal banner line"/>
                            <TextBlock Text="Single-Line Banner Mode" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Compacts notifications into one line per card. Turn off for stacked multi-line cards."
                                   Style="{StaticResource SettingDesc}"/>

                        <StackPanel Visibility="{Binding SingleLineMode, Converter={StaticResource BoolToVis}}">
                            <DockPanel Margin="0,0,0,4">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding SingleLineWrapText}"
                                              ToolTip="Allow one-line banner content to wrap instead of truncating"/>
                                <TextBlock Text="Wrap Banner Text" Style="{StaticResource SettingLabel}"/>
                            </DockPanel>
                            <TextBlock Text="Useful on smaller monitors: preserves content by wrapping onto additional lines."
                                       Style="{StaticResource SettingDesc}"/>

                            <TextBlock Text="Banner Max Lines" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding SingleLineMaxLines, StringFormat='{}{0:0}'}"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="1" Maximum="12" Value="{Binding SingleLineMaxLines}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ToolTip="Maximum wrapped lines per banner card in single-line mode"/>
                            </DockPanel>
                            <TextBlock Text="Lower values keep more cards visible at once; higher values show more text per card."
                                       Style="{StaticResource SettingDesc}"/>

                            <DockPanel Margin="0,0,0,4">
                                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding SingleLineAutoFullWidth}"
                                              ToolTip="Automatically expand banner width to near full monitor width"/>
                                <TextBlock Text="Auto Full-Width Banner" Style="{StaticResource SettingLabel}"/>
                            </DockPanel>
                            <TextBlock Text="When enabled, single-line mode spans almost the full monitor width automatically."
                                       Style="{StaticResource SettingDesc}"/>
                        </StackPanel>

                        <TextBlock Text="WINDOW" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AlwaysOnTop}"
                                          ToolTip="Keep the overlay above all other windows"/>
                            <TextBlock Text="Always on Top" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="When enabled, the overlay floats above all other windows including full-screen apps"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ClickThrough}"
                                          ToolTip="Allow mouse clicks to pass through the overlay"/>
                            <TextBlock Text="Click-Through Mode" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Mouse clicks pass through the overlay so you can interact with windows behind it. Disable to drag/resize the overlay."
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="ANIMATIONS" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AnimationsEnabled}"
                                          ToolTip="Enable or disable slide and fade animations"/>
                            <TextBlock Text="Enable Animations" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Smooth slide-in and fade-out transitions for notifications"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding FadeOnlyAnimation}"
                                          ToolTip="Use fade transitions only (no side movement)"/>
                            <TextBlock Text="Fade-Only Animation" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Useful if motion is distracting or you prefer a calmer transition style"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Slide-In Direction" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Style="{StaticResource SettingsComboBox}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItem}"
                                  ItemsSource="{Binding AvailableSlideDirections}"
                                  SelectedItem="{Binding SlideInDirection}"
                                  ToolTip="Which direction cards slide in from"
                                  Margin="0,4,0,0"/>
                        <TextBlock Text="Direction notifications slide in from (overridden when fade-only is enabled)"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Animation Speed" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding AnimationDurationMs, StringFormat='{}{0:0}'}"/><Run Text="ms"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="1200" Value="{Binding AnimationDurationMs}"
                                    TickFrequency="25" IsSnapToTickEnabled="True"
                                    ToolTip="Duration of slide/fade animations in milliseconds"/>
                        </DockPanel>
                        <TextBlock Text="0 means instant transitions; higher values feel smoother"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="DEDUPLICATION" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding DeduplicationEnabled}"
                                          ToolTip="Skip duplicate notifications that arrive within the dedup window"/>
                            <TextBlock Text="Deduplicate Notifications" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Suppresses identical notifications that arrive in quick succession"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Dedup Window" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding DeduplicationWindowSeconds, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="0.5" Maximum="10" Value="{Binding DeduplicationWindowSeconds}"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    ToolTip="Time window for considering notifications as duplicates"/>
                        </DockPanel>
                        <TextBlock Text="How long (in seconds) to consider identical notifications as duplicates"
                                   Style="{StaticResource SettingDesc}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ FILTERING TAB ═══ -->
            <TabItem Header="Filtering" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <TextBlock Text="PER-APP MUTING" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Apps seen this session appear below. Toggle to mute/unmute."
                                   Style="{StaticResource SettingDesc}"/>

                        <ItemsControl ItemsSource="{Binding MutedAppEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right" Content="{Binding IsMuted, Converter={StaticResource BoolToMuteLabel}}"
                                                Style="{StaticResource SecondaryButton}" MinWidth="72"
                                                Command="{Binding DataContext.ToggleMuteAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding AppName}"/>
                                        <TextBlock Text="{Binding AppName}" Style="{StaticResource SettingLabel}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No apps seen yet — notifications will populate this list"
                                   Style="{StaticResource SettingDesc}" Margin="0,4,0,0"
                                   Visibility="{Binding MutedAppEntries.Count, Converter={StaticResource ZeroToVisible}}"/>

                        <TextBlock Text="KEYWORD HIGHLIGHTING" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Notifications matching these keywords get a colored accent stripe"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Highlight Color" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="6"
                                    Background="{Binding HighlightColor, Converter={StaticResource ColorToBrush}}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Content="Pick"
                                    Style="{StaticResource ColorPickButton}" Margin="8,0,0,0"
                                    Tag="HighlightColor" Click="OnPickColorClick"
                                    ToolTip="Open color picker for highlight accent"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding HighlightColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hex color for highlighted notification accent"
                                     MaxLength="7"/>
                        </DockPanel>
                        <TextBlock Text="Accent color used for keyword-matched notification cards"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,4,0,0">
                            <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" Command="{Binding AddHighlightKeywordCommand}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewHighlightKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Type a keyword and click Add"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding HighlightKeywords}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <Button DockPanel.Dock="Right" Content="X" Style="{StaticResource SecondaryButton}"
                                                MinWidth="28" Padding="6,2"
                                                Command="{Binding DataContext.RemoveHighlightKeywordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding}" Style="{StaticResource SettingLabel}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="KEYWORD MUTING" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Notifications containing these keywords will be silently suppressed"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,4,0,0">
                            <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" Command="{Binding AddMuteKeywordCommand}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NewMuteKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Type a keyword and click Add"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding MuteKeywords}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <Button DockPanel.Dock="Right" Content="X" Style="{StaticResource SecondaryButton}"
                                                MinWidth="28" Padding="6,2"
                                                Command="{Binding DataContext.RemoveMuteKeywordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding}" Style="{StaticResource SettingLabel}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="QUIET HOURS" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding QuietHoursEnabled}"
                                          ToolTip="Automatically suppress notifications during specified hours"/>
                            <TextBlock Text="Enable Quiet Hours" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Silences all notifications between the start and end times"
                                   Style="{StaticResource SettingDesc}"/>

                        <StackPanel Visibility="{Binding QuietHoursEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Start Time (HH:mm)" Style="{StaticResource SettingLabel}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding QuietHoursStart, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Time to begin suppressing notifications (24h format)"
                                     MaxLength="5"/>
                            <TextBlock Text="e.g. 22:00 for 10 PM" Style="{StaticResource SettingDesc}"/>

                            <TextBlock Text="End Time (HH:mm)" Style="{StaticResource SettingLabel}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding QuietHoursEnd, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Time to stop suppressing notifications (24h format)"
                                     MaxLength="5"/>
                            <TextBlock Text="e.g. 08:00 for 8 AM" Style="{StaticResource SettingDesc}"/>
                        </StackPanel>

                        <TextBlock Text="BURST LIMITING" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding BurstLimitEnabled}"
                                          ToolTip="Auto-suppress when too many notifications arrive in a short window"/>
                            <TextBlock Text="Enable Burst Limiting" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Prevents notification storms from flooding the overlay"
                                   Style="{StaticResource SettingDesc}"/>

                        <StackPanel Visibility="{Binding BurstLimitEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Max Notifications" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding BurstLimitCount, StringFormat='{}{0:0}'}"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="2" Maximum="50" Value="{Binding BurstLimitCount}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ToolTip="Max notifications allowed within the burst window"/>
                            </DockPanel>
                            <TextBlock Text="Number of notifications allowed before suppression kicks in"
                                       Style="{StaticResource SettingDesc}"/>

                            <TextBlock Text="Burst Window" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding BurstLimitWindowSeconds, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="1" Maximum="30" Value="{Binding BurstLimitWindowSeconds}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ToolTip="Time window in seconds for burst detection"/>
                            </DockPanel>
                            <TextBlock Text="How many seconds to count notifications over"
                                       Style="{StaticResource SettingDesc}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ POSITION TAB ═══ -->
            <TabItem Header="Position" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <TextBlock Text="SIZE" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Overlay Width" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OverlayWidth, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="220" Maximum="7680" Value="{Binding OverlayWidth}"
                                    TickFrequency="20" IsSnapToTickEnabled="True"
                                    ToolTip="Width of the overlay window in pixels"/>
                        </DockPanel>
                        <TextBlock Text="Wider overlays show more text per line and work best with single-line mode"
                                   Style="{StaticResource SettingDesc}"/>
                        <TextBlock Text="Width Presets" Style="{StaticResource SettingLabel}"/>
                        <WrapPanel Margin="0,4,0,8" ItemWidth="88">
                            <Button Content="1080p" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="1080p"/>
                            <Button Content="2K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="2k"/>
                            <Button Content="4K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="4k"/>
                            <Button Content="8K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayWidthPresetCommand}" CommandParameter="8k"/>
                        </WrapPanel>
                        <TextBlock Text="Quickly set width targets for common display classes."
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AllowManualResize}"
                                          ToolTip="Allow drag-resizing from left/right edges of the overlay"/>
                            <TextBlock Text="Allow Manual Resize" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="When enabled, drag the left or right edge of the overlay to resize quickly"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Max Overlay Height" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding OverlayMaxHeight, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="200" Maximum="4320" Value="{Binding OverlayMaxHeight}"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    ToolTip="Maximum height the overlay can grow to before scrolling"/>
                        </DockPanel>
                        <TextBlock Text="The overlay expands vertically as needed up to this limit, then scrolls"
                                   Style="{StaticResource SettingDesc}"/>
                        <TextBlock Text="If long stacked notifications appear cut off, increase this value or scroll within the overlay. Effective height is still clamped to your active monitor's work area."
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Height Presets" Style="{StaticResource SettingLabel}"/>
                        <WrapPanel Margin="0,4,0,8" ItemWidth="88">
                            <Button Content="1080p" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="1080p"/>
                            <Button Content="2K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="2k"/>
                            <Button Content="4K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="4k"/>
                            <Button Content="8K" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding SetOverlayHeightPresetCommand}" CommandParameter="8k"/>
                        </WrapPanel>
                        <TextBlock Text="Quickly set max-height targets for common display classes."
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="SNAPPING" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding SnapToEdges}"
                                          ToolTip="Overlay snaps to screen edges when dragged nearby"/>
                            <TextBlock Text="Snap to Screen Edges" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="The overlay automatically aligns to screen edges when dragged close to them"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="Snap Distance" Style="{StaticResource SettingLabel}"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                <Run Text="{Binding SnapDistance, StringFormat='{}{0:0}'}"/><Run Text="px"/>
                            </TextBlock>
                            <Slider Style="{StaticResource SettingsSlider}"
                                    Minimum="5" Maximum="50" Value="{Binding SnapDistance}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ToolTip="How close to a screen edge before the overlay snaps"/>
                        </DockPanel>
                        <TextBlock Text="How close (in pixels) the overlay needs to be before it snaps into place"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="QUICK POSITION" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Move overlay to common screen positions"
                                   Style="{StaticResource SettingDesc}"/>
                        <WrapPanel Margin="0,0,0,8" ItemWidth="120">
                            <Button Content="Top Left" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="top-left"/>
                            <Button Content="Top Center" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="top-center"/>
                            <Button Content="Top Right" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="top-right"/>
                            <Button Content="Middle Left" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="middle-left"/>
                            <Button Content="Middle Right" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding MoveOverlayPresetCommand}" CommandParameter="middle-right"/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ═══ ACCESSIBILITY TAB ═══ -->
            <TabItem Header="Accessibility" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>

                        <TextBlock Text="NOTIFICATION TIMING" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding PersistentNotifications}"
                                          ToolTip="Notifications stay on screen until manually dismissed"/>
                            <TextBlock Text="Persistent Notifications" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Notifications remain visible until you click to dismiss them (no auto-expiry)"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AutoDurationEnabled}"
                                          ToolTip="Automatically extend display time for longer notifications"/>
                            <TextBlock Text="Auto-Duration (Longer Text = More Time)" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Calculates display time based on notification length so you have time to read"
                                   Style="{StaticResource SettingDesc}"/>

                        <StackPanel Visibility="{Binding AutoDurationEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Base Duration" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding AutoDurationBaseSeconds, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="2" Maximum="30" Value="{Binding AutoDurationBaseSeconds}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ToolTip="Minimum display time before per-line additions"/>
                            </DockPanel>
                            <TextBlock Text="Starting duration before adding time per line of text"
                                       Style="{StaticResource SettingDesc}"/>

                            <TextBlock Text="Seconds Per Line" Style="{StaticResource SettingLabel}"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SliderValue}">
                                    <Run Text="{Binding AutoDurationSecondsPerLine, StringFormat='{}{0:0.0}'}"/><Run Text="s"/>
                                </TextBlock>
                                <Slider Style="{StaticResource SettingsSlider}"
                                        Minimum="0.5" Maximum="5" Value="{Binding AutoDurationSecondsPerLine}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ToolTip="Extra display time added per estimated line of text"/>
                            </DockPanel>
                            <TextBlock Text="Additional seconds added for each line of notification body text"
                                       Style="{StaticResource SettingDesc}"/>
                        </StackPanel>

                        <TextBlock Text="SYSTEM INTEGRATION" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding RespectReduceMotion}"
                                          ToolTip="Disable slide animations when Windows 'Reduce Motion' is active"/>
                            <TextBlock Text="Respect Reduce Motion" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Automatically disables slide animations when Windows animation settings are off"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding RespectHighContrast}"
                                          ToolTip="Auto-apply High Contrast theme when Windows HC mode is active"/>
                            <TextBlock Text="Respect High Contrast" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Automatically switches to the High Contrast built-in theme when Windows HC mode activates"
                                   Style="{StaticResource SettingDesc}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding RespectTextScaling}"
                                          ToolTip="Scale overlay font sizes according to Windows text scaling setting"/>
                            <TextBlock Text="Respect Text Scaling" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Scales notification text to match your Windows accessibility text size setting"
                                   Style="{StaticResource SettingDesc}"/>

                        <TextBlock Text="GLOBAL HOTKEYS" Style="{StaticResource SectionHeader}"/>

                        <DockPanel Margin="0,0,0,4">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding GlobalHotkeysEnabled}"
                                          ToolTip="Register system-wide keyboard shortcuts"/>
                            <TextBlock Text="Enable Global Hotkeys" Style="{StaticResource SettingLabel}"/>
                        </DockPanel>
                        <TextBlock Text="Register system-wide keyboard shortcuts to control the overlay without the mouse"
                                   Style="{StaticResource SettingDesc}"/>

                        <StackPanel Visibility="{Binding GlobalHotkeysEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Toggle Overlay" Style="{StaticResource SettingLabel}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding HotkeyToggleOverlay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Keyboard combo to show/hide the overlay (e.g. Ctrl+Alt+N)"/>
                            <TextBlock Text="Show or hide the notification overlay" Style="{StaticResource SettingDesc}"/>

                            <TextBlock Text="Dismiss All" Style="{StaticResource SettingLabel}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding HotkeyDismissAll, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Keyboard combo to clear all visible notifications (e.g. Ctrl+Alt+D)"/>
                            <TextBlock Text="Clear all visible notifications at once" Style="{StaticResource SettingDesc}"/>

                            <TextBlock Text="Toggle Do Not Disturb" Style="{StaticResource SettingLabel}"/>
                            <TextBox Style="{StaticResource SettingsTextBox}" Margin="0,4,0,0"
                                     Text="{Binding HotkeyToggleDnd, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Keyboard combo to pause/resume notifications (e.g. Ctrl+Alt+P)"/>
                            <TextBlock Text="Pause or resume notification delivery" Style="{StaticResource SettingDesc}"/>
                        </StackPanel>

                        <TextBlock Text="INFORMATION DENSITY" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Quick presets that adjust font sizes, padding, spacing, and line limits at once"
                                   Style="{StaticResource SettingDesc}"/>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="Compact" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ApplyDensityPresetCommand}" CommandParameter="Compact"
                                    ToolTip="Smaller text, tighter spacing — fits more notifications on screen"/>
                            <Button Content="Comfortable" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ApplyDensityPresetCommand}" CommandParameter="Comfortable"
                                    ToolTip="Default balanced layout with readable sizing"/>
                            <Button Content="Spacious" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ApplyDensityPresetCommand}" CommandParameter="Spacious"
                                    ToolTip="Larger text, generous spacing — easier to read at a distance"/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer with preview button -->
        <Border Grid.Row="2" Padding="24,16" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Reset to Defaults" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetToDefaultsCommand}" Margin="0,0,8,0"
                            ToolTip="Restore all settings to their original values"/>
                    <Button Content="Send Test Notification" Style="{StaticResource PrimaryButton}"
                            Command="{Binding PreviewNotificationCommand}"
                            ToolTip="Shows a sample notification in the overlay so you can preview your current style settings"/>
                </StackPanel>
                <TextBlock Text="Changes are saved automatically" VerticalAlignment="Center"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
